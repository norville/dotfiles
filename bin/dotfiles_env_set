#!/bin/sh

set -e

git submodule update --remote --recursive
git submodule update --init --recursive

# Check for Homebrew and install if we don't have it, else update it
if test ! $(which brew); then
	/usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
else
	brew update --force
	brew upgrade --cleanup
fi

# Install all our dependencies with bundle (See Brewfile)
brew tap homebrew/bundle
brew bundle -v --file=brew/Brewfile
brew cleanup

# Install PIP pacjages
pip3 install --upgrade pip wheel setuptools pip-review

# Set ZSH as login shell
ZSH_PATH=$(which zsh)

if [ $SHELL == $ZSH_PATH ]
then
	echo "ZSH is already the login shell."
else
	echo "Changing login shell to ZSH..."
	echo $ZSH_PATH | sudo tee -a /etc/shells
	chsh -s $ZSH_PATH
fi

# Install Vundle plugins
vim +PluginInstall +qall

