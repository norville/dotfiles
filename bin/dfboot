# - break into IDEMPOTENT functions - respect ORDER:
# - • sudo -v
#   • prep (repo)
#   • df_get_pkgs (min sw)
#   • df_env (shell, plugins, editor)
#   • code (dev frameworks)

### Define variables and functions

# Local paths
BARE_DIR=.dfbare                    # git dir name for bare repo
BAKP_DIR=$HOME/.dfbackup            # backup dir for pre-existing dotfiles
ANT_DIR=$HOME/.antigen              # antigen plugins dir
APT_PKGS=$HOME/.dfconf/apt-packages # required APT packages
BRW_PKGS=$HOME/.dfconf/Brewfile     # required brew packages
VNDL_DIR=$HOME/.vim/bundle          # Vundle plugins dir
FONT_DIR=$HOME/.fonts

# Remote URLs
REPO_URL='https://github.com/norville/dotfiles.git'
BREW_URL='https://raw.githubusercontent.com/Homebrew/install/master/install'
VNDL_URL='https://github.com/VundleVim/Vundle.vim.git'
FONT_URL='https://github.com/ryanoasis/nerd-fonts/blob/master/patched-fonts/Meslo/M/Regular/complete/Meslo%20LG%20M%20Regular%20Nerd%20Font%20Complete.ttf'

# Check last exit status and print message
function df_exit_status() {

    if [[ $? != 0 ]]; then
        # Print error message and exit
        echo "Error $1"
        exit 2
    else
        # Print success message
        echo "Done $1"
    fi

}

function df_message() {

    echo $1

}

# Automatically run git against the bare repo in $HOME
function dfconf {
    # /usr/bin/git --git-dir=<git-bare-dir> --work-tree=<dotfiles-dir>
    /usr/bin/git --git-dir=$BARE_DIR --work-tree=$HOME $@
}

# Clone dotfiles into a local bare repo
function df_clone_bare {

    df_message "Checking local bare repo"

    # If git is not installed exit now
    if [[ ! $(which git) ]]; then
        sudo apt-get install -y git
    fi

    # Set bare repo dir
    cd $HOME
    mkdir -p $BARE_DIR
    cd $BARE_DIR

    # If bare repo is not already set
    if [[ ! $(git rev-parse --is-bare-repository) ]]; then

        # Clone remote repo into bare repo
        cd $HOME
        #git clone --bare $REPO_URL $BARE_DIR           # Clone master branch
        git clone --bare -b bare $REPO_URL $BARE_DIR    # Clone specifc branch
        df_exit_status "cloning bare repo into $BARE_DIR"

        # Checkout bare repo
        dfconf checkout
        # If checkout fails
        if [[ $? != 0 ]]; then
            # Create backup dir
            mkdir -p $BAKP_DIR
            # Move pre-existing dotfiles to $BAKP_DIR
            dfconf checkout 2>&1 | egrep "\s+\." | awk {'print $1'} | xargs -I{} mv {} $BAKP_DIR/{}
            dfconf checkout
        fi
        df_exit_status "checking out bare repo"

        # Config bare repo to ignore untracked files
        dfconf config status.showUntrackedFiles no

    fi

    # Ensure current dir is $HOME
    cd $HOME

    df_message "Bare repo ready"
}

# Get last version of Homebrew and install a bundle of packages if given
function df_brew() {

    # Check if bundle is valid
    if [[ ! -f $1 ]]; then
        # bundle not valid
        exit 1
        #TODO handle error message
    else

        # Install Homebrew if missing
        if [[ ! $(which brew) ]]; then
            /usr/bin/ruby -e "$(curl -fsSL $BREW_URL)"
            df_exit_status "installing Homebrew"
        fi

        # Install bundle if not up to date
        if [[ ! $(brew bundle check --file=$1) ]]; then
            brew bundle -v --file=$1
            df_exit_status "installing bundle $1"
        fi

        # Remove extra packages if requested
        if [[ $(brew bundle cleanup --file=$1) ]]; then
            read -r -p "Found extra packages, do you want to uninstall them? [y|n] " response
            if [[ $response =~ (yes|y|Y) ]]; then
                brew bundle cleanup --file=$1 --force
                df_exit_status "removing extra packages"
            fi
        fi

        # Update Homebrew
        brew update --force
        df_exit_status "updating Homebrew"

        # Upgrade all formulae
        brew upgrade
        df_exit_status "upgrading Homebrew formulae"

        # Upgrade all casks
        brew cask upgrade #--greedy
        df_exit_status "upgrading Homebrew caks"

        # Do some maintenance
        brew cleanup
        brew doctor

    fi
}

# Install or update required packages
function df_get_pkgs() {

    df_message "Getting required packages"

    # Detect system
    if [[ $(uname -s) == 'Linux' ]]; then

        # System is Linux

        # Install or update required packages via APT
        # TODO make it distro indipendent: support yum and arch pkgs
        xargs -a $APT_PKGS sudo apt-get install -y
        df_exit_status "installing required packages in $APT_PKGS"

        # Cleanup
        sudo apt autoremove
        sudo apt autoclean

        # TODO install meslo nerd
        mkdir -p $FONT_DIR
        wget -O $FONT_DIR/MesloNerdComplete.ttf $FONT_URL

    else

        # System is macOS

        df_brew $BRW_PKGS

        # Update PIP base packages
        pip3 install -U pip setuptools wheel
        df_exit_status "updating PIP packages"

    fi

    # Install/update antigen
    if [[ -d $ANT_DIR ]]; then
        rm -rf $ANT_DIR
    fi
    mkdir -p $ANT_DIR
    curl -L git.io/antigen > $ANT_DIR/antigen.zsh

    df_message "Required packages ready"
}

# Configure the environment
function df_env() {

    df_message "Configuring this environment"

    df_message "Configuring the shell"

    # Ensure ZSH is the login shell
    ZSH_PATH=$(which zsh)
    if [[ $SHELL != $ZSH_PATH ]]; then

        # Set ZSH as login shell
        echo $ZSH_PATH | sudo tee -a /etc/shells
        sudo chsh -s $ZSH_PATH $USER
        df_exit_status "setting ZSH as login shell"

    fi

    df_message "Configuring the editor"

    # Install or update Vundle and required plugins
    if [[ ! -d $VNDL_DIR/Vundle.vim ]]; then
        # Download Vundle
        git clone $VNDL_URL $VNDL_DIR/Vundle.vim
        df_exit_status "installing Vundle"
    fi

    # Update Vundle and required plugins
    vim -i NONE -c VundleUpdate -c quitall > /dev/null 2>&1
    df_exit_status "updating Vundle plugins"

    # TODO
    # - LNX set gruvbox theme for terminal
    # - LNX restore preferences
    # - MAC restore preferences (Mackup / Mathias)

    df_message "Environment ready"
}

### Bootstrap begin

set -e

# Get admin privileges
sudo -v

### Prepare bare repo
df_clone_bare

### Install or update required software
df_get_pkgs

### Configure environment
df_env

### Bootstrap end

# TODO countdown to reboot
