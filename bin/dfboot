#!/bin/bash

# TODO
# - .ssh/{config,known_hosts}
# - SSH Keys generation and copy
# - /etc/hosts
# - colorize bdb_exit_status
# - user interaction
# - --silent / --verbose flags

### Prepare for execution

# Force exit in case of error
set -e

# Call error handler before exiting
trap "bdb_handle_error" EXIT

# Provide --help flag
if [ ${#@} -ne 0 ] && [ "${@#"--help"}" = "" ]; then
    printf -- '...help...\n'
    exit 0
fi

### Define variables

# Output colors
ESC_SEQ="\x1b["
COL_RESET=$ESC_SEQ"39;49;00m"
COL_RED=$ESC_SEQ"31;01m"
COL_GREEN=$ESC_SEQ"32;01m"
COL_YELLOW=$ESC_SEQ"33;01m"
COL_BLUE=$ESC_SEQ"34;01m"
COL_MAGENTA=$ESC_SEQ"35;01m"
COL_CYAN=$ESC_SEQ"36;01m"
COL_WHITE=$ESC_SEQ"97;01m"

# Local paths
BARE_DIR="$HOME/.dfbare"     # git dir name for bare repo
BAKP_DIR="$HOME/.dfbackup"   # backup dir for pre-existing dotfiles
ANTG_DIR="$HOME/.antigen"    # antigen plugins dir
VNDL_DIR="$HOME/.vim/bundle" # Vundle plugins dir

# Remote URLs
REPO_URL="https://github.com/norville/dotfiles.git"
BREW_URL="https://raw.githubusercontent.com/Homebrew/install/master/install"
VNDL_URL="https://github.com/VundleVim/Vundle.vim.git"

# Required packages
UBNT_PKG="vim git wget curl zsh python3-pip"
PYPI_PKG="pip setuptools wheel autopep8 flake8"
BREW_PKG="$HOME/.dfconf/brewfile"

### Define functions

function bdb_handle_error() {

    ERR_CODE=$?
    if [[ $ERR_CODE != 0 ]]; then
        printf -- "Error ${ERR_CODE} has occurred."
        # TODO - handle exit codes and cleanup
        printf -- "\nExiting with error code ${ERR_CODE}.\n"
        exit ${ERR_CODE}
    fi

}

# Check last exit status and print outcome message
function bdb_exit_status() {

    if [[ $? != 0 ]]; then
        # Print error message and exit
        echo -e "\n$COL_RED|xxx| ERROR $1 $COL_RESET"
    else
        # Print success message
        echo -e "$COL_GREEN|+++| DONE $1 $COL_RESET"
    fi

}

# Print info message - NEWLINE
function bdb_info() {

    echo -e "\n$COL_WHITE|BDB| $1 $COL_RESET"

}

# Print run message - NO NEWLINE
function bdb_run() {

    echo -en "\n$COL_BLUE|***| $1 ... $COL_RESET"

}

# Print outcome message - INLINE
function bdb_outcome() {

    echo -e "$COL_CYAN$1$COL_RESET"

}

# Print message before command - NEWLINE
function bdb_command() {

    echo -e "\n$COL_MAGENTA|>>>| $1 $COL_RESET"

}

# Check the system and prepare for bootstrap
function bdb_check_sys() {

    # Detect system
    bdb_run "Running BDB on a "
    if [[ $(uname -s) == 'Darwin' ]]; then
        export MACOS="true"
        bdb_outcome "macOS system"
    else
        bdb_outcome "Linux system"
    fi

    # Get admin privileges
    #TODO no newline after password input
    bdb_run "Getting admin privileges"
    sudo -v

    # Check system requirements
    bdb_run "Checking system requirements"
    if [[ ! $MACOS ]]; then

        bdb_outcome "for Linux"

        if [[ ! $(which git) ]]; then
            bdb_command "Installing git"
            sudo apt install -y $UBNT_PKG
            bdb_exit_status "installing git"
        fi

    fi

    bdb_info "System ready"

}

# Automatically run git against the bare repo in $HOME
function dfconf() {

    # /usr/bin/git --git-dir=<git-bare-dir> --work-tree=<dotfiles-dir>
    /usr/bin/git --git-dir=$BARE_DIR --work-tree=$HOME $@

}

# Clone dotfiles into a local bare repo
function bdb_clone_repo() {

    bdb_run "Looking for dotfiles"

    # Set bare repo dir
    mkdir -p $BARE_DIR

    # If bare repo is not already set
    if [[ ! $(git --git-dir=$BARE_DIR rev-parse --is-bare-repository) ]]; then

        export NEWSYS="true"

        # Clone remote repo into bare repo
        bdb_command "Dotfiles not found, cloning remote repo into a bare one"
        #git clone --bare $REPO_URL $BARE_DIR           # Clone master branch
        git clone --bare -b bare $REPO_URL $BARE_DIR # Clone specifc branch
        bdb_exit_status "cloning bare repo into $BARE_DIR"

        # Checkout bare repo
        bdb_command "Checking out dotfiles repo"
        dfconf checkout
        # If checkout fails
        # TODO prevent checkout from exiting before doing a backup
        if [[ $? != 0 ]]; then
            # Create backup dir
            bdb_command "Backing up overlapping dotfiles"
            mkdir -p $BAKP_DIR
            # Move pre-existing dotfiles to $BAKP_DIR
            dfconf checkout 2>&1 | egrep "\s+\." | awk {'print $1'} | xargs -I{} mv {} $BAKP_DIR/{}
            dfconf checkout
        fi
        bdb_exit_status "checking out bare repo"

        # Config bare repo to ignore untracked files
        dfconf config status.showUntrackedFiles no

    fi

    #TODO handle remote pull if repo is set

    bdb_info "Dotfiles ready"

}

# Install or update packages
function bdb_get_packages() {

    bdb_run "Getting required packages"

    # Detect system
    if [[ $MACOS ]]; then

        # System is macOS
        bdb_outcome "for macOS"

        # Check Homebrew
        if [[ ! $(which brew) ]]; then

            # Install Homebrew
            bdb_command "Installing Homebrew"
            /usr/bin/ruby -e "$(curl -fsSL $BREW_URL)"
            bdb_exit_status "installing Homebrew"

        else

            # Update Homebrew
            bdb_command "Updating Homebrew"
            brew update
            bdb_exit_status "updating Homebrew"

        fi

        # Install or update ?
        if [[ $NEWSYS ]]; then

            # Install brew bundle
            bdb_command "Installing required formulae from <$BREW_PKG>"
            brew bundle install --file=$BREW_PKG
            bdb_exit_status "installing required formulae"

        else

            # Check extra formulae
            bdb_run "Checking installed formulae"
            if [[ $(brew bundle cleanup --file=$BREW_PKG) ]]; then

                # Extra packages installed
                bdb_run "Found extra formulae, do you want to uninstall them? [y|n] "
                read -r response
                if [[ $response =~ (yes|y|Y) ]]; then
                    # Delete extra packages
                    bdb_command "Removing extra formulae"
                    brew bundle cleanup --file=$BREW_PKG --force
                    bdb_exit_status "removing extra formulae"
                fi

            else
                bdb_outcome "nothing found"
            fi

            # Upgrade all formulae
            bdb_command "Upgrading all formulae"
            brew upgrade
            bdb_exit_status "upgrading all formulae"

            # Upgrade all casks
            bdb_command "Upgrading all casks"
            brew cask upgrade --greedy
            bdb_exit_status "upgrading all casks"

        fi

        # Cleanup
        bdb_command "Cleaning Homebrew"
        brew cleanup
        brew doctor
        bdb_exit_status "cleaning Homebrew"

        # Update PIP base packages
        bdb_command "Updating PIP packages: <$PYPI_PKG>"
        pip3 install -U $PYPI_PKG
        bdb_exit_status "updating PIP packages"

    else

        # System is Linux
        bdb_outcome "for Ubuntu"

        # Install or update required packages via APT
        bdb_command "Installing APT packages: <$UBNT_PKG>"
        sudo apt update && sudo apt install -y $UBNT_PKG
        bdb_exit_status "installing APT packages"

        # Cleanup
        bdb_command "Cleaning APT"
        sudo apt autoremove
        sudo apt autoclean
        bdb_exit_status "cleaning APT"

    fi

    # Install/update antigen
    bdb_command "Installing Antigen"
    if [[ -d $ANTG_DIR ]]; then
        rm -rf $ANTG_DIR
    fi
    mkdir -p $ANTG_DIR
    curl -L git.io/antigen >$ANTG_DIR/antigen.zsh
    bdb_exit_status "installing Antigen"

    bdb_info "Required packages ready"

}

# Configure the environment
function bdb_set_env() {

    bdb_info "Configuring this environment"

    # Ensure ZSH is the login shell
    bdb_run "Configuring the shell"
    ZSH_PATH=$(which zsh)
    if [[ $SHELL != $ZSH_PATH ]]; then

        # Set ZSH as login shell
        bdb_command "Setting ZSH as the login shell"
        echo $ZSH_PATH | sudo tee -a /etc/shells
        sudo chsh -s $ZSH_PATH $USER
        bdb_exit_status "setting ZSH as the login shell"

    else
        bdb_outcome "ZSH is already the login shell"
    fi

    # Install or update Vundle and required plugins
    bdb_run "Configuring the editor"
    if [[ ! -d $VNDL_DIR/Vundle.vim ]]; then

        # Install Vundle
        bdb_command "Installing Vundle - VIM plugin manager"
        git clone $VNDL_URL $VNDL_DIR/Vundle.vim
        bdb_exit_status "installing Vundle"

    fi
    # Update Vundle and required plugins
    bdb_command "Updating VIM plugins via Vundle"
    vim -i NONE -c VundleUpdate -c quitall >/dev/null 2>&1
    bdb_exit_status "updating Vundle plugins"

    # User preferences
    if [[ $NEWSYS ]]; then

        bdb_run "Restoring user preferences"
        if [[ $MACOS ]]; then

            #bdb_command "Restoring macOS preferences"
            #TODO Mathias
            #bdb_exit_status "restoring macOS preferences"

            bdb_command "Restoring App preferences"
            mackup restore
            bdb_exit_status "restoring App preferences"

        else

            #bdb_command "Restoring Linux preferences"
            #TODO GNU Stow
            #bdb_exit_status "restoring Linux preferences"

        fi

    fi

    bdb_info "Environment ready"

}

### Bootstrap begin
bdb_info "Welcome to Bassa Dofiles Bootstrapper (BDB)!"

# Checkthe system
bdb_check_sys

# Prepare bare repo
bdb_clone_repo

# Install or update required software
bdb_get_packages

# Configure environment
bdb_set_env

### Bootstrap end
bdb_info "All done!"

# Exit in style
printf -- '\n'
exit 0
