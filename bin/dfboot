#!/bin/bash

# TODO
# - SSH Keys generation and copy: centic9/generate-and-send-ssh-key
# - colorize bdb_exit_status

{ # ensure download of entire script

    ### Define constants

    ESC_SEQ="\x1b["
    RST_COL="${ESC_SEQ}39;49;00m" # reset
    RED_COL="${ESC_SEQ}31;01m"    # red
    GRN_COL="${ESC_SEQ}32;01m"    # green
    BLU_COL="${ESC_SEQ}34;01m"    # blue
    YLW_COL="${ESC_SEQ}33;01m"    # yellow
    CYN_COL="${ESC_SEQ}36;01m"    # cyan
    MGN_COL="${ESC_SEQ}35;01m"    # magenta
    WHT_COL="${ESC_SEQ}97;01m"    # white

    FRESH=""                         # true = fresh install
    DISTRO=""                        # unix distro name
    SYSTEM=""                        # os name
    BARE_DIR="${HOME}/.dfbare"       # git bare repo dir
    CONF_DIR="${HOME}/.dfconf.d"     # config files dir
    LOGFILE="${CONF_DIR}/dfboot.log" # dfboot log file
    PROGNAME="$(basename "$0")"      # current running command

    ### Define functions

    # Automatically run git against the bare repo in ${HOME}
    dfconf() {

        # /usr/bin/git --git-dir=<git-bare-dir> --work-tree=<dotfiles-dir>
        /usr/bin/git --git-dir="${BARE_DIR}" --work-tree="${HOME}" $@

    }

    # Handle exit codes, print messages and clean up
    bdb_handle_error() {

        ERR_CODE=$?

        # TODO - handle exit codes and cleanup (MENU)

        printf -- "Error ${ERR_CODE} has occurred."
        printf -- "\nExiting with error code ${ERR_CODE}.\n"
        exit ${ERR_CODE}

    }

    # Check last exit status and print outcome message
    bdb_exit_status() {

        # If last command exit status is not 0
        if [[ "$?" != 0 ]]; then

            # Print error message
            echo -e "\n${RED_COL}|xxx| ERROR ${1:-"UNKNOWN"} ${RST_COL}"
            # Handle error
            bdb_handle_error

        else

            # Print success message
            echo -en "${GRN_COL}|vvv| DONE ${1:-"UNKNOWN"} ${RST_COL}"

        fi

    }

    # Print alert message
    bdb_alert() {

        echo -en "\n${YLW_COL}|!!!| $1 ${RST_COL}"

    }

    # Print info message
    bdb_begin_info() {

        echo -en "\n|BDB| BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB |BDB|"
        echo -en "\n|BDB| vvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvvv"
        echo -en "\n|BDB|"
        echo -en "\n|BDB| $1"
        echo -en "\n|BDB|"

    }

    # Print info message
    bdb_end_info() {

        echo -en "\n|BDB|"
        echo -en "\n|BDB| $1"
        echo -en "\n|BDB|"
        echo -en "\n|BDB| ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^"

    }

    # Print run message
    bdb_run() {

        echo -en "\n${BLU_COL}|###| $1 ... ${RST_COL}"

    }

    # Print outcome message
    bdb_outcome() {

        echo -en "${CYN_COL}$1${RST_COL}"

    }

    # Print message before command
    bdb_command() {

        echo -e "\n${MGN_COL}|>>>| $1 ${RST_COL}"

    }

    # Ask user yes/no, return 0 for yes (default: no)
    bdb_ask() {

        # Print prompt
        echo -en "\n${WHT_COL}|???| ---------------------------------------------------------------------------------"
        echo -en "\n${WHT_COL}|???|"
        echo -en "\n${WHT_COL}|???| $1? [y|N] > "
        echo -en "\n${WHT_COL}|???|"
        echo -en "\n${WHT_COL}|???| ---------------------------------------------------------------------------------"
        echo -en "${RST_COL}"

        # Read user input: suppress output, read 1 char
        read -s -r -n 1 response

        # If input = y/Y
        if [[ $response =~ (y|Y) ]]; then

            # Return success
            return 0

        fi

        # Default: return error
        return 1

    }

    # Check the system and prepare for bootstrap
    bdb_do_sys() {

        bdb_begin_info "Prepare local system for bootstrap"

        ## Get admin privileges
        bdb_run "Getting admin privileges"
        #TODO no newline after password input
        sudo -v

        ## Detect local system
        bdb_run "Local system is"
        LSB_NAME="/etc/os-release"
        # If /etc/os-release exists
        if [[ -f "${LSB_NAME}" ]]; then

            # System is Linux, then get os name
            SYSTEM="$(grep -e '^ID=' ${LSB_NAME} | cut -d '=' -f 2)"

        else

            # /etc/os-release is missing, assume macos
            SYSTEM="macos"

        fi
        case "${SYSTEM}" in

        ubuntu | debian | raspbian) DISTRO="debian" ;;
        manjaro* | arch) DISTRO="arch" ;;
        macos) DISTRO="darwin" ;;
        *) DISTRO="unknown" ;;

        esac
        bdb_outcome "${SYSTEM} (${DISTRO})"

        ## Prepare local system: update packages cache and install requirements
        case "${DISTRO}" in

        arch)
            bdb_command "Updating Pacman"
            sudo pacman -Syy
            bdb_exit_status "updating Pacman"
            ;;

        darwin)
            # CLT check
            bdb_run "Checking Xcode Command Line Tools"
            if type xcode-select >&- &&
                CLT_DIR=$(xcode-select --print-path) &&
                test -d "${CLT_DIR}" &&
                test -x "${CLT_DIR}"; then

                # CLT installed
                bdb_outcome "OK."

            else

                # CLT not installed
                bdb_outcome "not found."
                bdb_command "Installing CLT"
                # on 10.9+, we can leverage SUS to get the latest CLI tools
                # create the placeholder file that's checked by CLI updates' .dist code
                # in Apple's SUS catalog
                touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress
                # find the CLI Tools update
                PROD=$(softwareupdate -l | grep "\*.*Command Line" | head -n 1 | awk -F"*" '{print $2}' | sed -e 's/^ *//' | tr -d '\n')
                # install it
                softwareupdate -i "$PROD" -v
                bdb_exit_status "installing CLT"

            fi

            # If brew is missing
            if ! type brew &>/dev/null; then

                # Install homebrew
                BREW_URL="https://raw.githubusercontent.com/Homebrew/install/master/install"
                bdb_command "Installing Homebrew"
                /usr/bin/ruby -e "$(curl -fsSL ${BREW_URL})"
                bdb_exit_status "installing Homebrew"

            else

                # Update homebrew
                bdb_command "Updating Homebrew"
                brew update
                bdb_exit_status "updating Homebrew"

            fi
            ;;

        debian)
            bdb_command "Updating APT"
            sudo apt-get update
            bdb_exit_status "updating APT"

            # If git is missing
            if ! type git &>/dev/null; then

                #Install git
                bdb_command "Installing git"
                sudo apt-get install -y git
                bdb_exit_status "installing git"

            fi
            ;;

        *)
            bdb_exit_status "Cannot detect local system. Exiting..."
            #TODO improve error handling
            exit 1
            ;;

        esac

        bdb_end_info "System ready"

    }

    # Check dotfiles repo
    bdb_do_repo() {

        bdb_begin_info "Detect dotfiles or clone remote repository"

        bdb_run "Looking for dotfiles"
        # Set bare repo dir
        mkdir -p "${BARE_DIR}"
        # If bare repo is missing
        if [[ ! "$(git --git-dir=${BARE_DIR} rev-parse --is-bare-repository)" ]]; then

            # Fresh system
            FRESH="true"

            # TODO - pipe error output
            bdb_outcome "none found. Let's clone remote repo!"

            # Clone remote repo into bare repo
            REPO_URL="https://github.com/norville/dotfiles.git"
            bdb_command "Cloning dotfiles into a bare repo"
            git clone --bare "${REPO_URL}" "${BARE_DIR}" # Clone master branch
            #git clone --bare -b <git-branch> ${REPO_URL} ${BARE_DIR}   # Clone specifc branch
            bdb_exit_status "cloning dotfiles into <${BARE_DIR}>"

            # Checkout bare repo
            bdb_command "Checking out dotfiles repo"
            dfconf checkout
            # If checkout fails
            # TODO prevent checkout from exiting before doing a backup
            if [[ "$?" != 0 ]]; then

                # Create backup dir
                BAKP_DIR="${HOME}/.dfbackup"
                bdb_command "Backing up overlapping dotfiles"
                mkdir -p "${BAKP_DIR}"
                # Move pre-existing dotfiles to ${BAKP_DIR}
                dfconf checkout 2>&1 | egrep "\s+\." | awk {'print $1'} | xargs -I{} mv {} "${BAKP_DIR}"/{}
                dfconf checkout

            fi
            bdb_exit_status "checking out bare repo"

            # Set remote Github via ssh
            dfconf remote set-url origin git@github.com:norville/dotfiles.git
            # Set Github as remote upstream
            dfconf push --set-upstream origin master

        else

            # repo ok, run git status
            bdb_outcome "local bare repo ok"
            bdb_command "Showing repo status"
            dfconf status -u
            bdb_exit_status "showing repo status"

        fi

        bdb_end_info "Dotfiles ready"

    }

    # Install or update packages
    bdb_do_apps() {

        bdb_begin_info "Bootstrap applications"

        # Detect system
        case "${DISTRO}" in

        darwin) # System is macOS

            # Install brew bundles
            BREW_PKG="${CONF_DIR}/brewfile"
            bdb_command "Installing required formulae from <${BREW_PKG}>"
            brew bundle install --file="${BREW_PKG}"
            bdb_exit_status "installing required formulae"

            # If extra formulae are installed
            if [[ "$(brew bundle cleanup --file=${BREW_PKG})" ]]; then

                # If response is yes (true)
                (bdb_ask "uninstall extra formulae" && {

                    # Delete extra formulae
                    bdb_command "Removing extra formulae"
                    brew bundle cleanup --file="${BREW_PKG}" --force
                    bdb_exit_status "removing extra formulae"

                }) || { # Response is no (false)

                    # Upgrade all formulae
                    bdb_command "Upgrading all formulae"
                    brew upgrade
                    bdb_exit_status "upgrading all formulae"

                }

            fi

            # Cleanup
            bdb_command "Cleaning Homebrew"
            brew cleanup
            bdb_exit_status "cleaning Homebrew"

            ;;

        debian) # System is debian

            # Install or update required packages via APT
            DEBN_PKG="vim git wget curl keychain zsh"
            bdb_command "Installing APT packages: <${DEBN_PKG}>"
            sudo apt-get install -y $DEBN_PKG # NO QUOTES PLEASE - ensure variable expasnsion
            bdb_exit_status "installing APT packages"

            # Cleanup
            bdb_command "Cleaning APT"
            sudo apt autoremove
            sudo apt autoclean
            bdb_exit_status "cleaning APT"

            ;;

        arch) # System is arch

            # Install or update required packages via Pacman
            ARCH_PKG="vim git wget curl keychain zsh tilix"
            bdb_command "Installing Arch packages: <${ARCH_PKG}>"
            sudo pacman --noconfirm --needed -S $ARCH_PKG # NO QUOTES PLEASE - ensure variable expasnsion
            bdb_exit_status "installing Arch packages"

            # Cleanup
            bdb_command "Cleaning Pacman cache"
            sudo pacman --noconfirm -Scc
            bdb_exit_status "cleaning Pacman cache"

            ;;

        *) # Distro not detected
            bdb_alert "Unknown system: ${DISTRO}. Exiting..."
            # TODO improve error handling
            bdb_handle_error 10
            ;;

        esac

        bdb_end_info "Applications ready"

    }

    # Upgrade local system
    bdb_do_upgrade() {

        bdb_begin_info "Upgrade local system"

        case "${DISTRO}" in

        arch)
            bdb_command "Upgrading Arch system"
            sudo pacman --noconfirm -Syu
            bdb_exit_status "upgrading Arch system"
            ;;
        darwin)
            bdb_command "Upgrading macOS system"
            sudo softwareupdate -ia
            bdb_exit_status "upgrading macOS system"
            ;;
        debian)
            bdb_command "Upgrading Debian system"
            sudo apt upgrade -y
            bdb_exit_status "upgrading Debian system"
            ;;

        esac

        bdb_end_info "System upgraded."

    }

    # Configure user environment
    bdb_do_env() {

        bdb_begin_info "Configure user environment"

        # Configure login shell on linux
        if [[ "${DISTRO}" != "darwin" ]]; then

            bdb_run "Configuring ZSH as your login shell"
            ZSH_PATH="$(which zsh)"
            # If zsh is not the login shell
            if [[ "${SHELL}" != "${ZSH_PATH}" ]]; then

                # Set zsh as login shell
                bdb_command "Switching to ZSH"
                echo "${ZSH_PATH}" | sudo tee -a /etc/shells
                sudo chsh -s "${ZSH_PATH}" "${USER}"
                bdb_exit_status "switching to ZSH"

            else

                # Zsh is the login shell
                bdb_outcome "done"

                # Delete antigen dir to force cloning
                if [[ -d "${HOME}/.antigen" ]]; then

                    bdb_command "Updating Antigen"
                    rm -rf "${HOME}"/.antigen
                    bdb_exit_status "updating Antigen"

                fi

            fi

        fi

        # Install or update vundle and required plugins
        VNDL_DIR="${HOME}/.vim/bundle"
        bdb_run "Configuring VIM as your text editor"
        # If vundle is missing
        if [[ ! -d "${VNDL_DIR}/Vundle.vim" ]]; then

            # Install vundle
            VNDL_URL="https://github.com/VundleVim/Vundle.vim.git"
            bdb_command "Installing Vundle - VIM plugin manager"
            git clone "${VNDL_URL}" "${VNDL_DIR}"/Vundle.vim
            bdb_exit_status "installing Vundle"

        fi

        # Update vundle and required plugins
        bdb_command "Updating VIM plugins via Vundle"
        vim -i NONE -c VundleUpdate -c quitall >/dev/null 2>&1
        bdb_exit_status "updating Vundle plugins"

        #Restore user preferences
        case "${DISTRO}" in

        arch)
            bdb_run "Restoring Tilix fonts"

            # Install nerd fonts for p10k
            FONT_DIR="${HOME}/.local/share/fonts"
            FURA_FNT="Fura Mono Regular Nerd Font.otf"
            MSLO_FNT="Meslo LG S Regular Nerd Font.ttf"
            FURA_URL="https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/FiraMono/Regular/complete/Fura%20Mono%20Regular%20Nerd%20Font%20Complete.otf"
            MSLO_URL="https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/Meslo/S/Regular/complete/Meslo%20LG%20S%20Regular%20Nerd%20Font%20Complete.ttf"

            mkdir -p "${FONT_DIR}"
            bdb_command "Installing Fura Mono"
            curl -fLo "${FONT_DIR}/${FURA_FNT}" "${FURA_URL}"
            bdb_exit_status "installing Fura Mono"
            bdb_command "Installing Meslo"
            curl -fLo "${FONT_DIR}/${MSLO_FNT}" "${MSLO_URL}"
            bdb_exit_status "installing Meslo"
            bdb_command "Updating fonts cache"
            fc-cache -f
            bdb_exit_status "updating fonts cache"

            bdb_run "Restoring Tilix colorscheme"

            # Install Gruvbox theme for Tilix
            bdb_command "Installing Gruvbox theme"
            git clone https://github.com/MichaelThessel/tilix-gruvbox.git
            cd tilix-gruvbox
            sudo cp gruvbox-* /usr/share/tilix/schemes
            cd ..
            rm -rf tilix-gruvbox
            bdb_exit_status "installing Gruvbox theme"

            bdb_run "Restoring Tilix configuration"

            # Check config file
            TILIX_CFG="${CONF_DIR}/tilix.dconf"
            if [[ -f "${TILIX_CFG}" ]]; then

                bdb_command "Loading dconf profile"
                dconf load /com/gexperts/Tilix/ <"${TILIX_CFG}"
                bdb_exit_status "loading dconf profile"

            else

                bdb_outcome "FAILED"

            fi

            #TODO GNU Stow or mackup

            ;;

        macos)

            # If this is a fresh system
            if [[ "${FRESH}" ]]; then

                # Set macos defaults
                bdb_command "Restoring macOS preferences"
                MAC_DEF="${HOME}/bin/macos_defaults"
                [[ "${MAC_DEF}" ]] && source "${MAC_DEF}"
                bdb_exit_status "restoring macOS preferences"

                # Run mackup
                bdb_command "Restoring App preferences"
                type mackup &>/dev/null && mackup restore
                bdb_exit_status "restoring App preferences"

            fi

            # Restore VSCode extensions
            CODE_EXT="${CONF_DIR}/vscode-ext"
            # If no extensions installed and extensions file exists
            if [[ ! "$(code --list-extensions)" && -f "${CODE_EXT}" ]]; then

                bdb_command "Installing VSCode extensions"
                cat "${CODE_EXT}" | xargs -n 1 code --install-extension
                bdb_exit_status "installing VSCode extensions"

            fi

            ;;

        *) # Nothing to do
            ;;

        esac

        bdb_end_info "User environment ready"

    }

    # Print help message and exit
    bdb_usage() {

        # Print error message if passed
        [[ $2 ]] && {
            bdb_alert "error: $2"
            bdb_alert ""
        }
        bdb_alert "usage: $PROGNAME [<option> ...]"
        bdb_alert ""
        bdb_alert "       $PROGNAME [-h]"
        bdb_alert "       $PROGNAME [-f] [-s|-v] [-l <logfile>]"
        bdb_alert "       $PROGNAME [-r|-a|-e|-u] [-s|-v] [-l <logfile>]"
        bdb_alert ""
        bdb_alert "options: -h           : Print this message and exit"
        bdb_alert "         -f           : Full bootstrap"
        bdb_alert "         -r           : Bootstrap dotfiles repository"
        bdb_alert "         -a           : Bootstrap required applications"
        bdb_alert "         -e           : Bootstrap user environment"
        bdb_alert "         -u           : Upgrade local system"
        bdb_alert "         -s           : Silence all terminal output"
        bdb_alert "         -v           : Send all output terminal"
        bdb_alert "         -l <logfile> : Send all output to <logfile>"
        bdb_alert "                        (default: ${LOGFILE})"

        bdb_end_info ""
        echo -en "\n|BDB| BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB |BDB|"

        # Exit with passed value
        exit $1
        # TODO - exit properly

    }

    ### Bootstrap begin

    # Force exit in case of error
    #set -e

    # Call error handler before exiting
    #trap "bdb_handle_error" EXIT

    bdb_begin_info "Welcome to Bassa Dotfiles Bootstrapper (BDB)"

    # Process command options
    while getopts ":hfraeusvl:" opt; do

        case $opt in
        h) # Print help message
            # TODO - fix combinations
            bdb_alert "optind: $OPTIND"
            if [[ ${OPTIND} -gt 2 ]]; then
                # Exit with error if 'h' flag is not alone
                bdb_usage 1 "invalid option: -h cannot be combined"
            fi
            bdb_usage 0
            ;;
        f) # Full bootstrap
            repo=1
            apps=1
            env=1
            upgrade=1
            ;;
        r) # Bootstrap repo
            repo=1
            ;;
        a) # Bootstrap apps
            repo=1
            apps=1
            ;;
        p) # Bootstrap env
            repo=1
            apps=1
            env=1
            ;;
        u) # Upgrade sys
            upgrade=1
            ;;
        l) # Print to logfile
            shift
            LOGFILE="$1"
            bdb_alert "logfile: ${LOGFILE}"
            ;;
        s) # Silent mode
            # TODO - suppress all output
            silent=1
            ;;
        v) # Verbose mode
            # TODO - print all commands output
            verbose=1
            ;;
        :) # Missing option argument, print usage and exit with error
            bdb_usage 1 "invalid option: -${OPTARG} requires an argument"
            ;;
        \?) # Invalid option, print usage and exit with error
            bdb_usage 1 "invalid option: -${OPTARG}"
            ;;
        esac

    done

    # getopts finished, shift to args
    shift $(($OPTIND - 1))

    # If command arguments are passed, exit with error
    if [[ $# -gt 0 ]]; then

        bdb_usage 1 "invalid argument: <$*>"

    fi

    # Always bootstrap system
    bdb_do_sys

    # If command options are passed
    if [[ $OPTIND -gt 1 ]]; then

        # Flag mode: bootstrap only flagged items
        [[ -n $repo ]] && bdb_do_repo
        [[ -n $apps ]] && bdb_do_apps
        [[ -n $env ]] && bdb_do_env
        [[ -n $upgrade ]] && bdb_do_upgrade

    else # Options not passed

        # Interactive mode: ask user what to bootstrap
        (bdb_ask "Bootstrap dotfiles repository" && bdb_do_repo) || {
            bdb_alert "Skipping repo bootstrap"
        }
        (bdb_ask "Bootstrap required applications" && bdb_do_apps) || {
            bdb_alert "Skipping applications bootstrap"
        }
        (bdb_ask "Bootstrap user environment" && bdb_do_env) || {
            bdb_alert "Skipping environment bootstrap"
        }
        (bdb_ask "Upgrade local system" && bdb_do_upgrade) || {
            bdb_alert "Skipping system upgrade"
        }

    fi

    ### Bootstrap done

    bdb_begin_info "Bootstrap done."
    bdb_ask "Reboot local system" && {

        bdb_end_info "Rebooting local system"
        echo -en "\n|BDB| BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB |BDB|"
        sudo reboot

    }

    bdb_end_info "Logging out user '${USER}'"
    echo -en "\n|BDB| BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB | BDB |BDB|"
    printf "\n"
    exit 0

} # ensure download of entire script
