// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ── Appearance ───────────────────────────────────────────────────────────────
  "buffer_font_family": "JetBrains Mono",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night Moon",
  },

  // ── Editor behaviour (mirrors nvim / LazyVim defaults) ────────────────────────
  "vim_mode": true,

  // Defer indent style, size, charset, and trailing-whitespace to ~/.editorconfig.
  // Mirrors vim.g.editorconfig = true in nvim/lua/config/options.lua.
  "use_editorconfig": true,

  // Format on save: off — run formatters manually, same as vim.g.autoformat = false.
  "format_on_save": "off",

  // Show both absolute and relative line numbers (matches LazyVim: number + relativenumber).
  "relative_line_numbers": true,

  // Keep 8 lines of context above/below the cursor (matches LazyVim: scrolloff = 8).
  "vertical_scroll_margin": 8,

  // No soft wrap (matches nvim default: wrap = false).
  "soft_wrap": "none",

  // ── Privacy ───────────────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ── Session ───────────────────────────────────────────────────────────────────
  "session": {
    "trust_all_worktrees": true,
  },

  // ── Extensions ───────────────────────────────────────────────────────────────
  // Zed auto-installs these on startup (auto_install_extensions setting).
  // Language server support for languages not built into Zed.
  "auto_install_extensions": {
    "ruby":       true,
    "java":       true,
    "lua":        true,
    "terraform":  true,
    "dockerfile": true,
    "sql":        true,
  },

  // ── Languages ─────────────────────────────────────────────────────────────────
  // Only languages where Zed's automatic defaults need explicit guidance.
  // Rust, Go, TypeScript, C/C++, JSON, YAML, TOML, HTML, CSS, Markdown, and Bash
  // are handled automatically — no entry needed.
  "languages": {
    // Use both pyright (completions + diagnostics) and ruff (formatting + linting).
    "Python": {
      "language_servers": ["pyright", "ruff"]
    },
  },
}
