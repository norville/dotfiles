#!/usr/bin/env bash
# =============================================================================
# BDB Update — Environment Update After `chezmoi update`
# =============================================================================
# Updates system packages, ZSH plugins, bat themes, font caches, and dev
# toolchains. Registered as a `[hooks.update.post]` hook in .chezmoi.toml.tmpl
# so it runs ONLY after `chezmoi update` — never on plain `chezmoi apply`
# (chezmoi has no "update-only" script class; run_after_ scripts run on every
# apply, which is not what we want for full system upgrades).
#
# Execution: chezmoi update (post hook)
# Location:  dot_config/bdb/executable_bdb_update.sh.tmpl
#            → deployed to ~/.config/bdb/bdb_update.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
# Hooks do not receive [scriptEnv], so fall back to the deployed helpers path.
# shellcheck disable=SC1090,SC1091
source "${HELPERS:-${HOME}/.config/bdb/bdb_helpers.sh}"

bdb_script_init "${BASH_SOURCE[0]}"

# =============================================================================
# SYSTEM UPDATE
# =============================================================================

bdb_begin_section "Environment Update After Chezmoi Update"
bdb_var "Machine type" "{{ .machine }}"

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* macOS                                                                 */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .chezmoi.os "darwin" }}

# -----------------------------------------------------------------------------
# macOS: Homebrew Updates
# -----------------------------------------------------------------------------

# Update and upgrade Homebrew packages
bdb_exec "Updating Homebrew" brew update
bdb_exec "Upgrading Homebrew packages" brew upgrade
bdb_success "Homebrew packages updated"

# Update Homebrew casks
bdb_exec "Upgrading Homebrew casks" brew upgrade --cask \
  font-jetbrains-mono \
  font-jetbrains-mono-nerd-font \
  kitty
bdb_success "Homebrew casks updated"

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Linux                                                                 */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- else if eq .chezmoi.os "linux" }}

# -----------------------------------------------------------------------------
# Linux: Package Manager Updates
# -----------------------------------------------------------------------------

  {{- if eq .packageManager "apt" }}

# Debian/Ubuntu: APT updates
bdb_exec "Updating package lists" sudo apt-get update
bdb_exec "Upgrading packages" sudo apt-get full-upgrade -y
bdb_exec "Removing unused packages" sudo apt-get autoremove --purge -y
bdb_exec "Cleaning package cache" sudo apt-get clean
bdb_success "APT packages updated"

# Update Snap packages if installed
if bdb_test_cmd "snap"; then
  bdb_exec "Updating Snap packages" sudo snap refresh
  bdb_success "Snap packages updated"
fi

  {{- else if eq .packageManager "dnf" }}

# Fedora/RHEL: DNF updates
bdb_exec "Upgrading packages" sudo dnf upgrade --refresh -y
bdb_exec "Removing unused packages" sudo dnf autoremove -y
bdb_exec "Cleaning package cache" sudo dnf clean all
bdb_success "DNF packages updated"

# Update Flatpak if installed
if bdb_test_cmd "flatpak"; then
  bdb_exec "Updating Flatpak packages" flatpak update -y
  bdb_success "Flatpak packages updated"
fi

  {{- else if eq .packageManager "pacman" }}

# Arch/Manjaro: Pacman updates
bdb_exec "Updating system packages" sudo pacman -Syu --noconfirm

# Clean orphaned packages
orphans="$(pacman -Qdtq 2>/dev/null || true)"
if [[ -n "${orphans}" ]]; then
  bdb_exec "Removing orphaned packages" bash -c "echo '${orphans}' | sudo pacman -Rns --noconfirm -"
fi

# Clean package cache
bdb_exec "Cleaning package cache" sudo pacman -Scc --noconfirm
bdb_success "Pacman packages updated"

# Update AUR packages if yay is installed
if bdb_test_cmd "yay"; then
  bdb_exec "Updating AUR packages" yay -Syu --noconfirm
  bdb_success "AUR packages updated"
fi

  {{- end }}

{{- end }}

# =============================================================================
# SHELL PLUGIN + APPLICATION UPDATES
# =============================================================================
{{- /* Server machines: only package upgrades above — skip everything below. */ -}}
{{- if ne .machine "server" }}

# -----------------------------------------------------------------------------
# Update ZSH Plugins (Zinit)
# -----------------------------------------------------------------------------
bdb_action "Updating ZSH plugins"

# Zinit must be sourced inside a zsh subprocess; it is a zsh plugin, not a binary
zinit_home="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ -d "${zinit_home}/.git" ]]; then
    bdb_exec "Updating Zinit and all plugins" \
        zsh -c "source '${zinit_home}/zinit.zsh' && zinit self-update && zinit update --all --quiet" || true
    bdb_success "ZSH plugins updated"
else
    bdb_warn "Zinit not found - skipping plugin updates"
fi

# -----------------------------------------------------------------------------
# Update bat Themes
# -----------------------------------------------------------------------------
# bat is installed as 'batcat' on Debian/Ubuntu — detect the name at runtime
_bat="$(command -v batcat || command -v bat || true)"
if [[ -n "${_bat}" ]]; then
    bdb_exec "Rebuilding bat theme cache" "${_bat}" cache --build
fi
unset _bat

{{- /* Font cache: Linux non-server only (fonts not installed on server) */ -}}
{{- if eq .chezmoi.os "linux" }}
# -----------------------------------------------------------------------------
# Update Font Cache (Linux)
# -----------------------------------------------------------------------------
if bdb_test_cmd "fc-cache"; then
    bdb_exec "Updating font cache" fc-cache -fv >/dev/null 2>&1
fi
{{- end }}

# -----------------------------------------------------------------------------
# Update Rust toolchain
# -----------------------------------------------------------------------------
if bdb_test_cmd "rustup"; then
    bdb_exec "Updating Rust toolchain" rustup update
    bdb_success "Rust toolchain updated"
fi

# -----------------------------------------------------------------------------
# Update Ruby user gems
# -----------------------------------------------------------------------------
if bdb_test_cmd "gem"; then
    bdb_exec "Updating bundler" gem update --user-install --no-document bundler
    bdb_exec "Updating erb"     gem update --user-install --no-document erb
    bdb_success "Ruby gems updated"
fi

{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================

bdb_script_end "Environment update complete"

exit 0
