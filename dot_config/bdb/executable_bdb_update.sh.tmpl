#!/usr/bin/env bash
# =============================================================================
# BDB Update — Environment Update After `chezmoi update`
# =============================================================================
# Updates system packages, ZSH plugins, bat themes, font caches, and dev
# toolchains. Registered as a `[hooks.update.post]` hook in .chezmoi.toml.tmpl
# so it runs ONLY after `chezmoi update` — never on plain `chezmoi apply`
# (chezmoi has no "update-only" script class; run_after_ scripts run on every
# apply, which is not what we want for full system upgrades).
#
# System package updates live in bdb_update_packages (bdb_helpers.sh), shared
# with bdb_bootstrap.sh.
#
# Execution: chezmoi update (post hook)
# Location:  dot_config/bdb/executable_bdb_update.sh.tmpl
#            → deployed to ~/.config/bdb/bdb_update.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
# Hooks do not receive [scriptEnv], so fall back to the deployed helpers path.
# shellcheck disable=SC1090,SC1091
source "${HELPERS:-${HOME}/.config/bdb/bdb_helpers.sh}"

bdb_script_init "${BASH_SOURCE[0]}"

# =============================================================================
# SYSTEM UPDATE
# =============================================================================

bdb_begin_section "Environment Update After Chezmoi Update"
bdb_var "Machine type" "{{ .machine }}"

bdb_update_packages

# =============================================================================
# SHELL PLUGIN + APPLICATION UPDATES
# =============================================================================
{{- /* Server machines: only package upgrades above — skip everything below. */ -}}
{{- if ne .machine "server" }}

# -----------------------------------------------------------------------------
# Update ZSH Plugins (Zinit)
# -----------------------------------------------------------------------------
bdb_action "Updating ZSH plugins"

# Zinit must be sourced inside a zsh subprocess; it is a zsh plugin, not a binary
zinit_home="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ -d "${zinit_home}/.git" ]]; then
    bdb_exec "Updating Zinit and all plugins" \
        zsh -c "source '${zinit_home}/zinit.zsh' && zinit self-update && zinit update --all --quiet" || true
    bdb_success "ZSH plugins updated"
else
    bdb_warn "Zinit not found - skipping plugin updates"
fi

# -----------------------------------------------------------------------------
# Update bat Themes
# -----------------------------------------------------------------------------
# bat is installed as 'batcat' on Debian/Ubuntu — detect the name at runtime
_bat="$(command -v batcat || command -v bat || true)"
if [[ -n "${_bat}" ]]; then
    bdb_exec "Rebuilding bat theme cache" "${_bat}" cache --build
fi
unset _bat

# -----------------------------------------------------------------------------
# Update Font Cache (Linux only — fc-cache does not exist on macOS)
# -----------------------------------------------------------------------------
if bdb_has_cmd "fc-cache"; then
    bdb_exec "Updating font cache" fc-cache -fv >/dev/null 2>&1
fi

# -----------------------------------------------------------------------------
# Update Rust toolchain
# -----------------------------------------------------------------------------
if bdb_test_cmd "rustup"; then
    bdb_exec "Updating Rust toolchain" rustup update
    bdb_success "Rust toolchain updated"
fi

# -----------------------------------------------------------------------------
# Update Ruby user gems
# -----------------------------------------------------------------------------
if bdb_test_cmd "gem"; then
    bdb_exec "Updating bundler" gem update --user-install --no-document bundler
    bdb_exec "Updating erb"     gem update --user-install --no-document erb
    bdb_success "Ruby gems updated"
fi

{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================

bdb_script_end "Environment update complete"

exit 0
