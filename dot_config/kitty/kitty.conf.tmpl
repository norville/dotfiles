## Color scheme
include             Tokyo-Night-Moon.conf
background_opacity  0.95

## Fonts
{{ if eq .chezmoi.os "linux" -}}
# Linux uses the plain "Nerd Font" variant at 12pt (HiDPI handled by compositor).
font_family       family='JetBrainsMono Nerd Font' style=Regular
font_size         12.0
{{ else if eq .chezmoi.os "darwin" -}}
# macOS uses the "Nerd Font Mono" variant at 15pt (Retina display scaling).
font_family       family='JetBrainsMono Nerd Font Mono' style=Regular
font_size         15.0
{{ end -}}
bold_font         auto
bold_italic_font  auto
disable_ligatures cursor
font_features     none
italic_font       auto

## Text cursor customization
cursor_shape            block
cursor_shape_unfocused  hollow

## Scrollback
scrollback_lines              5000
scrollback_pager_history_size 10
scrollbar                     never

## Mouse
strip_trailing_spaces smart

## Mouse actions
#

## Performance tuning
#

## Terminal bell
#

## Window layout
enabled_layouts           tall:bias=50;full_size=1;mirrored=false
remember_window_size      yes
remember_window_position  yes
window_margin_width       4
window_padding_width      8
{{ if eq .chezmoi.os "linux" -}}
# Linux: remove window decorations entirely (tiling WMs handle this).
hide_window_decorations   yes
{{ else if eq .chezmoi.os "darwin" -}}
# macOS: keep the resize handle but hide the titlebar for a cleaner look.
hide_window_decorations   titlebar-only
{{- end }}

## Tab bar
tab_bar_edge            bottom
tab_bar_style           powerline
tab_powerline_style     slanted
tab_bar_background      #1e2030  # ui_bg_dark — bar strip background
active_tab_background   #65bcff  # blue1      — bright active tab
active_tab_foreground   #1e2030  # ui_bg_dark — dark fg for contrast on bright blue
inactive_tab_background #394b70  # blue7      — muted inactive tab
inactive_tab_foreground #737aa2  # ui_dark5

## Advanced
shell_integration no-cursor no-title

