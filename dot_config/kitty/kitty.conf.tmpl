## Miscellaneous
# close ssh connections
map ctrl+alt+super+k  close_shared_ssh_connections

## Sessions
# save window state to a session file
map f1 save_as_session --use-foreground-process --base-dir ~/.config/kitty/sessions

# Browse session files inside a directory and pick one
map f4 goto_session ~/.local/share/kitty/sessions
