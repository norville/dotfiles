#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Install Required Packages
# =============================================================================
# Installs the core + distro-specific packages defined in .chezmoi.toml.tmpl.
# Package lists are centralized there; this script only handles installation.
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_00-required-packages.sh.tmpl
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
source "${HELPERS}"

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}" .tmpl | sed 's/^[0-9]*\.//')"
SCRIPT_LOG_FILE="${HOME}/.cache/chezmoi/$(date +%Y%m%d_%H%M%S)_${SCRIPT_NAME}.log"
mkdir -p "${HOME}/.cache/chezmoi" 2>/dev/null || true
bdb_init_logging "${SCRIPT_LOG_FILE}"

_bdb_log "========================================="
_bdb_log "Script: ${SCRIPT_NAME}"
_bdb_log "Started: $(date '+%Y-%m-%d %H:%M:%S')"
_bdb_log "========================================="

set -euo pipefail
trap 'bdb_handle_error' ERR
trap 'bdb_cleanup' EXIT

# =============================================================================
# PACKAGE INSTALLATION
# =============================================================================
{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Linux                                                                 */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .chezmoi.os "linux" }}

bdb_begin_section "Installing Required Packages for {{ .osid }}"

    {{- /* ---------------------------------------------------------------- */ -}}
    {{- /* Debian / Ubuntu — APT                                            */ -}}
    {{- /* ---------------------------------------------------------------- */ -}}
    {{- if eq .packageManager "apt" }}
# -----------------------------------------------------------------------------
# APT packages (Debian / Ubuntu)
# -----------------------------------------------------------------------------
APT_PACKAGES=(
  {{- range .corePackages }}
  "{{ . }}"
  {{- end }}
  {{- range .aptPackages }}
  "{{ . }}"
  {{- end }}
)

# eza is not in the official Debian/Ubuntu repos; add its signing key and
# custom source before apt-get update so everything resolves in one pass.
bdb_action "Setting up eza repository"
sudo mkdir -p /etc/apt/keyrings
wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
  | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
  | sudo tee /etc/apt/sources.list.d/eza.list
sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/eza.list

bdb_exec "Updating APT package lists" sudo apt-get update
bdb_exec "Installing APT packages"    sudo apt-get install -y "${APT_PACKAGES[@]}"

# -----------------------------------------------------------------------------
# Snap packages (Debian / Ubuntu)
# -----------------------------------------------------------------------------
# lazygit and nvim are absent from / outdated in the official apt repos;
# fresh-editor has no .deb release — all three are distributed only via snap.
# All packages in this list use --classic confinement; add non-classic snaps
# to a separate install call to avoid a confinement mismatch error.
SNAP_PACKAGES=(
  {{- range .snapPackages }}
  "{{ . }}"
  {{- end }}
)

if bdb_test_cmd "snap"; then
  bdb_exec "Refreshing installed snaps" sudo snap refresh
  # --classic cannot be combined with multiple packages in one call
  for _snap in "${SNAP_PACKAGES[@]}"; do
    bdb_exec "Installing snap: ${_snap}" sudo snap install --classic "${_snap}"
  done
  unset _snap
else
  bdb_warn "snapd is not installed — skipping: ${SNAP_PACKAGES[*]}"
fi

    {{- /* ---------------------------------------------------------------- */ -}}
    {{- /* Fedora / RHEL — DNF                                              */ -}}
    {{- /* ---------------------------------------------------------------- */ -}}
    {{- else if eq .packageManager "dnf" }}
# -----------------------------------------------------------------------------
# DNF packages (Fedora / RHEL)
# -----------------------------------------------------------------------------
DNF_PACKAGES=(
  {{- range .corePackages }}
  "{{ . }}"
  {{- end }}
  {{- range .dnfPackages }}
  "{{ . }}"
  {{- end }}
)

# Several packages are absent from the default Fedora repos; enable their COPR
# and Terra sources before the main install so everything resolves in one pass.
bdb_action "Enabling COPR repositories"
sudo dnf copr enable -y alternateved/eza   2>/dev/null || true  # eza
sudo dnf copr enable -y atim/lazygit       2>/dev/null || true  # lazygit
sudo dnf copr enable -y atim/starship      2>/dev/null || true  # starship
sudo dnf copr enable -y awood/bat-extras   2>/dev/null || true  # bat-extras
sudo dnf copr enable -y pennbauman/ports   2>/dev/null || true  # zoxide
bdb_success "COPR repositories enabled"

# Terra provides fresh-editor, which is absent from both Fedora repos and COPR.
bdb_action "Enabling Terra repository"
sudo dnf install -y --nogpgcheck --repofrompath 'terra,https://repos.fyralabs.com/terra$releasever' terra-release
bdb_success "Terra repository enabled"

bdb_exec "Installing DNF packages" sudo dnf install -y "${DNF_PACKAGES[@]}"

    {{- /* ---------------------------------------------------------------- */ -}}
    {{- /* Arch / Manjaro — Pacman + AUR                                    */ -}}
    {{- /* ---------------------------------------------------------------- */ -}}
    {{- else if eq .packageManager "pacman" }}
# -----------------------------------------------------------------------------
# Pacman packages (Arch / Manjaro)
# -----------------------------------------------------------------------------
PACMAN_PACKAGES=(
  {{- range .corePackages }}
  "{{ . }}"
  {{- end }}
  {{- range .pacmanPackages }}
  "{{ . }}"
  {{- end }}
)

bdb_exec "Installing Pacman packages" sudo pacman -S --needed --noconfirm "${PACMAN_PACKAGES[@]}"

        {{- /* ------------------------------------------------------------ */ -}}
        {{- /* AUR packages — skipped when aurPackages list is empty        */ -}}
        {{- /* ------------------------------------------------------------ */ -}}
        {{- if .aurPackages }}
# -----------------------------------------------------------------------------
# AUR packages (Arch / Manjaro)
# -----------------------------------------------------------------------------
# bat-extras and fresh-editor-bin are only in the AUR. yay is used as the
# helper because it wraps makepkg with a pacman-compatible interface.
if ! bdb_test_cmd "yay"; then
  bdb_action "Installing yay (AUR helper)"
  # makepkg -si calls sudo pacman twice (deps, then install); refresh the
  # timestamp once here so both calls share the same authenticated session.
  sudo -v
  git clone https://aur.archlinux.org/yay.git /tmp/yay
  (cd /tmp/yay && makepkg -si --noconfirm)
  rm -rf /tmp/yay
  bdb_success "yay installed"
else
  bdb_success "yay already installed"
fi

AUR_PACKAGES=(
  {{- range .aurPackages }}
  "{{ . }}"
  {{- end }}
)
bdb_exec "Installing AUR packages" yay -S --noconfirm "${AUR_PACKAGES[@]}"
        {{- end }}

    {{- end }}

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* macOS                                                                 */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- else if eq .chezmoi.os "darwin" }}

bdb_begin_section "Installing Required Packages for macOS"

# All macOS packages are declared in the Brewfile (formulae + casks + taps);
# brew bundle installs or upgrades them in a single idempotent pass.
BREWFILE="${HOME}/.config/homebrew/brewfile"

if [[ ! -f "${BREWFILE}" ]]; then
  bdb_error "Brewfile not found at ${BREWFILE}"
  exit 1
fi

bdb_var "Brewfile" "${BREWFILE}"
bdb_exec "Installing Homebrew packages" brew bundle --file="${BREWFILE}"

{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================
bdb_success "Required packages installed successfully"

if [[ -n "${BDB_LOG_FILE:-}" ]]; then
  bdb_var "Log file" "${BDB_LOG_FILE}"
fi

bdb_end_section

exit 0
