#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Environment Setup
# =============================================================================
# Configures the shell environment and application settings: bat theme cache,
# default shell (zsh), font cache, and dev toolchains (Go, Ruby, Rust).
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_01-config-env.sh.tmpl
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
source "${HELPERS}"

bdb_script_init "${BASH_SOURCE[0]}"

# =============================================================================
# ENVIRONMENT SETUP
# =============================================================================

bdb_begin_section "Environment Setup"

{{- if eq .machine "server" }}
bdb_warn "Skipping environment config — not applicable on server machines"
bdb_end_section
exit 0
{{- end }}

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# bat is installed as 'batcat' on Debian/Ubuntu — detect the name at runtime
_bat="$(command -v batcat || command -v bat || true)"
if [[ -n "${_bat}" ]]; then
    bdb_exec "Building bat theme cache" "${_bat}" cache --build
else
    bdb_warn "bat not found"
fi
unset _bat

# -----------------------------------------------------------------------------
# Go Environment
# -----------------------------------------------------------------------------

if bdb_test_cmd "go"; then
    bdb_action "Configuring Go environment"

    # Write explicit values to ~/.config/go/env so GOPATH/GOBIN are stable
    # across Go upgrades regardless of whether the tool changes its defaults.
    bdb_exec "Setting GOPATH" go env -w GOPATH="${HOME}/go"
    bdb_exec "Setting GOBIN"  go env -w GOBIN="${HOME}/go/bin"

    # Ensure standard GOPATH directory tree exists
    bdb_mkdir "${HOME}/go/bin" "Failed to create GOPATH/bin"
    bdb_mkdir "${HOME}/go/pkg" "Failed to create GOPATH/pkg"
    bdb_mkdir "${HOME}/go/src" "Failed to create GOPATH/src"

    bdb_var "GOPATH"      "$(go env GOPATH)"
    bdb_var "GOBIN"       "$(go env GOBIN)"
    bdb_var "Go version"  "$(go version)"
    bdb_success "Go environment configured"
else
    bdb_warn "go not installed — skipping Go environment setup"
fi

# -----------------------------------------------------------------------------
# Ruby Gems
# -----------------------------------------------------------------------------

if bdb_test_cmd "ruby" && bdb_test_cmd "gem"; then
    bdb_action "Installing required Ruby gems"

    # bundler: required by ruby-lsp to manage its internal bundle.
    # erb: required by rubocop (config loader, HTML formatter, server cache).
    # --user-install targets Gem.user_dir (same dir as GEM_HOME in .zshrc) so
    # these gems are never written to the root-owned system gem directory.
    bdb_exec "Installing bundler" gem install --user-install --no-document bundler
    bdb_exec "Installing erb"     gem install --user-install --no-document erb

    bdb_var "Gem user dir" "$(ruby -e 'puts Gem.user_dir' 2>/dev/null)"
    bdb_success "Ruby gems installed"
else
    bdb_warn "ruby/gem not installed — skipping Ruby gem setup"
fi

# -----------------------------------------------------------------------------
# Rust / rustup
# -----------------------------------------------------------------------------

if bdb_test_cmd "rustup"; then
    bdb_action "Configuring Rust toolchain"
    bdb_exec "Installing stable toolchain" rustup toolchain install stable
    bdb_exec "Setting default toolchain"   rustup default stable
    bdb_exec "Installing rust-analyzer"    rustup component add rust-analyzer
    bdb_var "Rust version"                 "$(rustc --version 2>/dev/null)"
    bdb_var "Cargo version"                "$(cargo --version 2>/dev/null)"
    bdb_success "Rust toolchain configured"
else
    bdb_warn "rustup not installed — skipping Rust setup"
fi

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Linux-Specific Configuration                                         */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .chezmoi.os "linux" }}
# -----------------------------------------------------------------------------
# Linux-Specific Configuration
# -----------------------------------------------------------------------------

bdb_action "Configuring default shell"

if bdb_test_cmd "zsh"; then
    zsh_path="$(command -v zsh)"
    bdb_var "ZSH path" "${zsh_path}"

    if [[ "${SHELL}" != "${zsh_path}" ]]; then
        # Ensure ZSH is in /etc/shells
        if ! grep -Fxq "${zsh_path}" /etc/shells 2>/dev/null; then
            bdb_exec "Adding ZSH to /etc/shells" bash -c "echo '${zsh_path}' | sudo tee -a /etc/shells >/dev/null"
        fi

        # Change default shell
        bdb_exec "Setting ZSH as default shell" sudo chsh -s "${zsh_path}" "${USER}"
        bdb_success "Shell changed to ZSH"
    else
        bdb_success "Already using ZSH as default shell"
    fi
else
    bdb_error "ZSH not found - cannot set as default shell"
fi

  {{- if or (eq .packageManager "apt") (eq .packageManager "dnf") }}
# Debian/Ubuntu/Fedora: fonts deployed by .chezmoiexternal.toml.tmpl — refresh
# the cache here; pacman/brew font packages maintain it themselves
if bdb_has_cmd "fc-cache"; then
    bdb_exec "Updating font cache" fc-cache -f
else
    bdb_warn "fc-cache command not found, cannot update font cache"
fi
  {{- end }}

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* macOS-Specific Configuration                                         */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- else if eq .chezmoi.os "darwin" }}
# -----------------------------------------------------------------------------
# macOS-Specific Configuration
# -----------------------------------------------------------------------------

# Configure Homebrew
bdb_action "Configuring Homebrew"
if bdb_test_cmd "brew"; then
    # Disable analytics
    bdb_exec "Disabling Homebrew analytics" brew analytics off 2>/dev/null || true
    bdb_success "Homebrew configured"
else
    bdb_warn "Homebrew not found"
fi

{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================

bdb_info "NOTE: Please log out and log back in for all changes to take effect"
bdb_script_end "Environment setup complete"

exit 0