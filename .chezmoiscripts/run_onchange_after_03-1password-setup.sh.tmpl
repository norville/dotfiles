#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: 1Password Initial Setup
# =============================================================================
# Verifies that op CLI is installed and a 1Password account is configured.
# Runs once per machine, after run_onchange_after_01 has had the chance to
# install op. SSH key templates that call onepasswordRead are gated in
# .chezmoiignore on `lookPath "op"`, so on a fresh machine a second
# `chezmoi apply` (after this script succeeds) will materialise the keys.
#
# Machine-aware: skips automatically on terminal machines (workstation only).
# Always asks for user confirmation before running.
#
# Execution: run_onchange_after_03 — fires when file content changes
# Location: .chezmoiscripts/run_onchange_after_03-1password-setup.sh.tmpl
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
# shellcheck disable=SC1090,SC1091
source "${HELPERS}"

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}" .tmpl | sed 's/^[0-9]*\.//')"
SCRIPT_LOG_FILE="${HOME}/.cache/chezmoi/$(date +%Y%m%d_%H%M%S)_${SCRIPT_NAME}.log"
mkdir -p "${HOME}/.cache/chezmoi" 2>/dev/null || true
bdb_init_logging "${SCRIPT_LOG_FILE}"

_bdb_log "========================================="
_bdb_log "Script: ${SCRIPT_NAME}"
_bdb_log "Started: $(date '+%Y-%m-%d %H:%M:%S')"
_bdb_log "========================================="

set -euo pipefail
trap 'bdb_handle_error' ERR
trap 'bdb_cleanup' EXIT

bdb_begin_section "1Password Setup"

{{- if ne .machine "workstation" }}
bdb_warn "Skipping 1Password setup — workstation machines only"
bdb_end_section
exit 0
{{- end }}

if ! bdb_ask "Run 1Password setup now"; then
  bdb_warn "Skipping 1Password setup"
  bdb_end_section
  exit 0
fi

# -----------------------------------------------------------------------------
# Launch 1Password app and wait for the agent socket
# -----------------------------------------------------------------------------
# The op CLI hangs immediately on a fresh machine if the 1Password daemon is
# not yet running — op account list and op whoami both block waiting for the
# socket. Launch the app first, then poll until the agent socket appears.

bdb_action "Launching 1Password app"

_op_socket=""

if [[ "$(uname -s)" == "Darwin" ]]; then
  _op_socket="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  open -a "1Password" 2>/dev/null || bdb_warn "Could not launch 1Password.app — launch it manually"
else
  _op_socket="${HOME}/.1password/agent.sock"
  # Try systemd user service first, then fall back to direct binary launch
  if bdb_has_cmd "systemctl"; then
    systemctl --user start 1password 2>/dev/null || true
  fi
  if ! pgrep -x "1password" >/dev/null 2>&1; then
    if bdb_has_cmd "1password"; then
      nohup 1password --silent >/dev/null 2>&1 &
    else
      bdb_warn "1Password app not found — launch it manually then re-run: chezmoi apply"
    fi
  fi
fi

bdb_action "Waiting for 1Password agent socket"
_waited=0
_timeout=60
until [[ -S "${_op_socket}" ]] || (( _waited >= _timeout )); do
  sleep 2
  (( _waited += 2 ))
done

if [[ -S "${_op_socket}" ]]; then
  bdb_success "1Password agent socket ready (${_waited}s)"
else
  bdb_warn "Agent socket not found after ${_timeout}s — op commands may hang"
  bdb_info "Open 1Password manually and re-run: chezmoi apply"
fi

unset _op_socket _waited _timeout

# -----------------------------------------------------------------------------
# Verify op CLI is available
# -----------------------------------------------------------------------------
# op is installed by run_onchange_after_01. If it is still missing here the
# user likely skipped that step — warn and exit cleanly so chezmoi does not
# error out; the script will re-run on the next `chezmoi apply` because
# run_once scripts re-run when their file content changes.
if ! bdb_test_cmd "op"; then
  bdb_warn "1Password CLI (op) not found — install it, then re-run: chezmoi apply"
  bdb_end_section
  exit 0
fi

bdb_var "op version" "$(op --version 2>/dev/null)"

# -----------------------------------------------------------------------------
# Ensure at least one account is configured
# -----------------------------------------------------------------------------
# op account list exits non-zero and prints nothing if no accounts are set up.
if ! op account list 2>/dev/null | grep -q "."; then
  bdb_action "No 1Password accounts configured — starting account setup"
  bdb_info "You will be prompted for your account address, email, and Secret Key"

  if ! op account add; then
    bdb_error "Failed to add 1Password account"
    bdb_info "Re-run 'chezmoi apply' after completing: op account add"
    bdb_end_section
    exit 1
  fi

  bdb_success "Account added"
fi

# -----------------------------------------------------------------------------
# Verify session / trigger authentication
# -----------------------------------------------------------------------------
# With biometric auth (1Password 8+) the system daemon manages sessions
# automatically and op whoami succeeds without any extra steps.
# On headless systems without biometric auth, eval "$(op signin)" starts an
# explicit session; chezmoi's [onepassword] prompt = true handles re-auth
# when the session expires during template processing.
bdb_action "Verifying 1Password session"

if op whoami >/dev/null 2>&1; then
  _account="$(op whoami 2>/dev/null | awk '/Email/ {print $2}')"
  bdb_success "Signed in${_account:+ as ${_account}}"
  unset _account
else
  bdb_action "Starting 1Password session"
  if eval "$(op signin 2>/dev/null)"; then
    bdb_success "Session started"
  else
    bdb_warn "Could not start session automatically"
    bdb_info "chezmoi will prompt for auth when reading each secret"
  fi
fi

bdb_success "1Password session ready"

# -----------------------------------------------------------------------------
# Verify SSH key deployment and permissions
# -----------------------------------------------------------------------------
# SSH key templates (gated in .chezmoiignore on lookPath "op") are deployed
# by the NEXT `chezmoi apply` now that op is available. This check reports
# whether keys are already in place and have the correct POSIX permissions.
#
# If no keys are found here, that is expected on a fresh machine — run
# `chezmoi apply` again after this script completes to deploy them.
#
# Expected permissions:
#   ~/.ssh/            → 700  (directory: owner-only access)
#   private key files  → 600  (owner read/write only — SSH refuses looser perms)
#   public key files   → 644  (world-readable; required for some SSH daemons)

bdb_action "Verifying SSH key deployment and permissions"

_ssh_dir="${HOME}/.ssh"
_key_ok=0
_key_issues=0

# Portable stat: GNU (Linux) uses -c '%a', BSD (macOS) uses -f '%Lp'
_stat_perms() { stat -c '%a' "$1" 2>/dev/null || stat -f '%Lp' "$1" 2>/dev/null || echo "unknown"; }

if [[ ! -d "${_ssh_dir}" ]]; then
  bdb_warn "~/.ssh not found — SSH keys not yet deployed"
  bdb_info "Run 'chezmoi apply' again to deploy SSH keys now that op is available"
else
  # Verify directory permissions
  _dir_perms="$(_stat_perms "${_ssh_dir}")"
  if [[ "${_dir_perms}" != "700" ]]; then
    bdb_warn "~/.ssh permissions ${_dir_perms} (expected 700)"
    _key_issues=$(( _key_issues + 1 ))
  fi

  # Check private keys: all regular files except .pub, config, known_hosts, authorized_keys
  while IFS= read -r -d '' _f; do
    _fname="$(basename "${_f}")"
    _perms="$(_stat_perms "${_f}")"
    if [[ "${_perms}" == "600" ]]; then
      bdb_success "${_fname}: ${_perms} (ok)"
      _key_ok=$(( _key_ok + 1 ))
    else
      bdb_warn "${_fname}: ${_perms} (expected 600)"
      _key_issues=$(( _key_issues + 1 ))
    fi
  done < <(find "${_ssh_dir}" -maxdepth 1 -type f \
    ! -name "*.pub" ! -name "config" ! -name "known_hosts" ! -name "authorized_keys" \
    -print0 2>/dev/null)

  # Check public keys
  while IFS= read -r -d '' _f; do
    _fname="$(basename "${_f}")"
    _perms="$(_stat_perms "${_f}")"
    if [[ "${_perms}" == "644" ]]; then
      bdb_success "${_fname}: ${_perms} (ok)"
      _key_ok=$(( _key_ok + 1 ))
    else
      bdb_warn "${_fname}: ${_perms} (expected 644)"
      _key_issues=$(( _key_issues + 1 ))
    fi
  done < <(find "${_ssh_dir}" -maxdepth 1 -type f -name "*.pub" -print0 2>/dev/null)

  if [[ ${_key_ok} -eq 0 && ${_key_issues} -eq 0 ]]; then
    bdb_warn "No SSH keys found in ~/.ssh — run 'chezmoi apply' to deploy them"
  elif [[ ${_key_issues} -gt 0 ]]; then
    bdb_warn "${_key_issues} SSH key permission issue(s) detected — check log for details"
  else
    bdb_success "All ${_key_ok} SSH key file(s) present with correct permissions"
  fi
fi

unset _ssh_dir _dir_perms _key_ok _key_issues _f _fname _perms
unset -f _stat_perms

# =============================================================================
# COMPLETION
# =============================================================================

bdb_success "1Password setup complete"

if [[ -n "${BDB_LOG_FILE:-}" ]]; then
  bdb_var "Log file" "${BDB_LOG_FILE}"
fi

bdb_end_section

exit 0
