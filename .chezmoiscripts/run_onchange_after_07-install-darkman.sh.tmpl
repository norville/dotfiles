#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Enable darkman Service
# =============================================================================
# Enables and starts the darkman systemd user service for automatic dark/light
# mode switching based on geographic position.
#
# Only runs on Linux workstations with a GNOME desktop environment.
# Requires darkman to be installed (via run_onchange_after_00-install-core.sh).
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_07-install-darkman.sh.tmpl
# =============================================================================
{{- if not (and (eq .machine "workstation") (eq .chezmoi.os "linux") (contains "gnome" (env "XDG_CURRENT_DESKTOP" | lower))) }}
exit 0
{{- end }}

source "${HELPERS}"

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}" .tmpl)"
SCRIPT_LOG_FILE="${HOME}/.cache/chezmoi/$(date +%Y%m%d_%H%M%S)_${SCRIPT_NAME}.log"
mkdir -p "${HOME}/.cache/chezmoi" 2>/dev/null || true
bdb_init_logging "${SCRIPT_LOG_FILE}"

_bdb_log "========================================="
_bdb_log "Script: ${SCRIPT_NAME}"
_bdb_log "Started: $(date '+%Y-%m-%d %H:%M:%S')"
_bdb_log "========================================="

set -euo pipefail
trap 'bdb_handle_error' ERR
trap 'bdb_cleanup' EXIT

# =============================================================================
# DARKMAN SERVICE
# =============================================================================

bdb_begin_section "Enabling darkman Service"

if ! bdb_has_cmd "darkman"; then
    bdb_warn "darkman not found — skipping service setup (install packages first)"
    bdb_end_section
    exit 0
fi

# Idempotency check: skip prompt and enable if already enabled and active.
if systemctl --user is-enabled darkman.service &>/dev/null \
   && systemctl --user is-active darkman.service &>/dev/null; then
    bdb_success "darkman.service is already enabled and running"
    bdb_end_section
    exit 0
fi

bdb_ask "Enable and start darkman.service?" || { bdb_warn "Skipped by user"; bdb_end_section; exit 0; }

bdb_exec "Enabling darkman.service" systemctl --user enable --now darkman.service
bdb_success "darkman.service enabled and started"

bdb_end_section

exit 0
