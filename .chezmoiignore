# =============================================================================
# Chezmoi Ignore File
# =============================================================================
# Canonical deployment scope per machine type — see ARCHITECTURE.md.
#
# Documentation: https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/
# =============================================================================

# -----------------------------------------------------------------------------
# Source-Only Directories (Never Installed)
# -----------------------------------------------------------------------------
# sddm/ holds system-level SDDM config and theme source files.
# Deployed to /etc/ and /usr/share/ by run_onchange_after_06-install-sddm.sh.
sddm/

# -----------------------------------------------------------------------------
# Repository / Tooling Files (Never Installed)
# -----------------------------------------------------------------------------
.gitignore
.claude
CLAUDE.md
ARCHITECTURE.md
README.md
TODO.md

# Bootstrap script (only used for initial setup, not deployed)
.config/bdb/bdb_bootstrap.sh

# -----------------------------------------------------------------------------
# Workstation-Only Paths — excluded on terminal and server
# -----------------------------------------------------------------------------
{{- if ne .machine "workstation" }}
.config/darkman/
.config/homebrew/
.config/kitty/
.config/niri/
.config/noctalia/
.config/yay/
.config/yazi/
.config/zed/
.local/share/darkman/
sddm/
{{- end }}

# -----------------------------------------------------------------------------
# Dev/TUI tool configs — excluded on server only
# -----------------------------------------------------------------------------
{{- if eq .machine "server" }}
.config/bat/
.config/btop/
.config/delta/
.config/eza/
.config/lazygit/
.config/nvim/
.config/starship/
.editorconfig
.ssh/
.zsh/
.zshrc
{{- end }}

# -----------------------------------------------------------------------------
# Conditional Paths — excluded when the relevant tool is absent
# -----------------------------------------------------------------------------

# niri: tiling compositor — deploy only when installed
{{- if not (lookPath "niri") }}
.config/niri/
{{- end }}

# noctalia: deploy only when installed
{{- if not (lookPath "qs") }}
.config/noctalia/
{{- end }}

# Noctalia plugins are managed by Noctalia's plugin manager, not chezmoi
.config/noctalia/plugins/

# darkman: GNOME only — excluded on all other desktops/WMs
{{- if not (contains "gnome" (env "XDG_CURRENT_DESKTOP" | lower)) }}
.config/darkman/
.local/share/darkman/
{{- end }}

# kitty session files are runtime artefacts — never track them
.config/kitty/sessions/*.kitty-session

# -----------------------------------------------------------------------------
# 1Password-Managed SSH Keys
# -----------------------------------------------------------------------------
# Skip when op is not installed. After run_onchange_after_02 installs
# 1Password, a second chezmoi apply will deploy these keys.
{{- if not (lookPath "op") }}
.ssh/norville_at_chikyu.pub
.ssh/ansible_at_chikyu.pub
.ssh/norville_at_github.pub
.ssh/norville_at_codeberg.pub
{{- end }}
