# =============================================================================
# Chezmoi Ignore File
# =============================================================================
# Files and directories listed here will not be copied to the target system
# Supports glob patterns and conditional logic using templates
#
# Documentation: https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/
# =============================================================================

# -----------------------------------------------------------------------------
# Repository Files (Never Install)
# -----------------------------------------------------------------------------
# Documentation and bootstrap scripts that should remain in the repository
ARCHITECTURE.md
README.md
TODO.md

# Bootstrap script (only used for initial setup)
.config/bdb/bdb_bootstrap.sh

# -----------------------------------------------------------------------------
# macOS-Specific Files
# -----------------------------------------------------------------------------
# Only install these files on macOS systems
{{- if ne .chezmoi.os "darwin" }}
.config/homebrew/
{{- end }}

# -----------------------------------------------------------------------------
# Machine-Type Exclusions
# -----------------------------------------------------------------------------
# workstation: vim is only a fallback binary; its config files are unused
{{- if eq .machine "workstation" }}
.vimrc
.vim/
{{- end }}

# headless / vm: no terminal emulator or fancy prompt
{{- if or (eq .machine "headless") (eq .machine "vm") }}
.config/kitty/
.config/starship/
{{- end }}

# vm: minimal install — skip configs for all tools not installed
{{- if eq .machine "vm" }}
.config/nvim/
.config/lazygit/
.config/btop/
.config/eza/
.config/bat/
.config/fresh/
{{- end }}

# -----------------------------------------------------------------------------
# Linux-Specific Files
# -----------------------------------------------------------------------------
# Only install these files on Linux systems
{{- if ne .chezmoi.os "linux" }}
{{- end }}

# -----------------------------------------------------------------------------
# Windows-Specific Files
# -----------------------------------------------------------------------------
# Only install these files on Windows systems
{{- if ne .chezmoi.os "windows" }}
{{- end }}

# -----------------------------------------------------------------------------
# Distribution-Specific Excludes
# -----------------------------------------------------------------------------
# Exclude package manager files based on distribution

{{- if ne .packageManager "apt" }}
# Not using APT - ignore Debian/Ubuntu specific files
{{- end }}

{{- if ne .packageManager "pacman" }}
# Not using Pacman - ignore Arch/Manjaro specific files
{{- end }}

{{- if ne .packageManager "dnf" }}
# Not using DNF - ignore Fedora/RHEL specific files
{{- end }}

# =============================================================================
# End of Ignore Configuration
# =============================================================================
