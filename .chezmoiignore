# =============================================================================
# Chezmoi Ignore File
# =============================================================================
# Files and directories listed here will not be copied to the target system
# Supports glob patterns and conditional logic using templates
#
# Documentation: https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/
# =============================================================================

# -----------------------------------------------------------------------------
# Source-Only Directories (Never Install)
# -----------------------------------------------------------------------------
# sddm/ holds system-level SDDM config and theme source files.
# They are deployed to /etc/ and /usr/share/ by run_onchange_after_06-sddm.sh,
# not to the home directory.
sddm/

# -----------------------------------------------------------------------------
# Claude Code Files (Never Install)
# -----------------------------------------------------------------------------
.gitignore
.claude
CLAUDE.md

# -----------------------------------------------------------------------------
# Repository Files (Never Install)
# -----------------------------------------------------------------------------
# Documentation and bootstrap scripts that should remain in the repository
ARCHITECTURE.md
README.md
TODO.md

# Bootstrap script (only used for initial setup)
.config/bdb/bdb_bootstrap.sh

# -----------------------------------------------------------------------------
# macOS-Specific Files
# -----------------------------------------------------------------------------
# Only install these files on macOS systems
{{- if ne .chezmoi.os "darwin" }}
.config/homebrew/
{{- end }}

# -----------------------------------------------------------------------------
# Machine-Type Exclusions
# -----------------------------------------------------------------------------
# workstation: neovim replaces vim; vim config files are unused
{{- if eq .machine "workstation" }}
.vimrc
.vim/
{{- end }}

# terminal: GUI/heavy tools are not installed
{{- if eq .machine "terminal" }}
.config/kitty/
.config/nvim/
.config/lazygit/
.config/btop/
{{- end }}

# darkman: GNOME Linux workstations only
{{- if not (and (eq .machine "workstation") (eq .chezmoi.os "linux") (contains "gnome" (env "XDG_CURRENT_DESKTOP" | lower))) }}
.config/darkman/
.local/share/darkman/
{{- end }}

# niri and noctalia are manually installed; deploy only when the packages are present
{{- if not (lookPath "niri") }}
.config/niri/
{{- end }}
{{- if not (lookPath "qs") }}
.config/noctalia/
{{- end }}

# Noctalia plugins are managed by Noctalia's plugin manager, not chezmoi
.config/noctalia/plugins/

# -----------------------------------------------------------------------------
# 1Password-Managed SSH Keys
# -----------------------------------------------------------------------------
# These templates call onepasswordRead at template-processing time.
# Skip them when op is not installed (e.g. on first apply of a fresh machine).
# After run_onchange_after_01 installs 1Password, a second chezmoi apply
# will process these files.
{{- if not (lookPath "op") }}
.ssh/norville_at_chikyu.pub
.ssh/ansible_at_chikyu.pub
.ssh/norville_at_github.pub
.ssh/norville_at_codeberg.pub
{{- end }}

