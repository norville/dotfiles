# =============================================================================
# SSH Client Configuration
# =============================================================================
# Private keys are stored in 1Password; the 1Password SSH agent handles
# authentication. IdentityFile points to the public key — the agent matches
# it to the corresponding private key it holds and signs the challenge.
# IdentitiesOnly prevents the agent from offering other unrelated keys.
# =============================================================================

Host *

{{- if eq .machine "workstation" }}
  {{- if eq .chezmoi.os "darwin" }}
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  {{- else if eq .chezmoi.os "linux" }}
    IdentityAgent ~/.1password/agent.sock
  {{- end }}
{{- end }}
    IdentitiesOnly yes  # offer only the keys listed below, not everything in the agent

Host jiraya
    Port 25355
    User norville
    IdentityFile ~/.ssh/norville_at_chikyu.pub
    ForwardAgent yes

Host hashirama asura indra shukaku matatabi isobu songoku kokuo nagato
    Port 25355
    User norville
    IdentityFile ~/.ssh/norville_at_chikyu.pub

Host github.com
    IdentityFile ~/.ssh/norville_at_github.pub
