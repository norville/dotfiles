{{- /* ========================================================================== */ -}}
{{- /* Chezmoi Configuration Template                                             */ -}}
{{- /* ========================================================================== */ -}}
{{- /* This file configures chezmoi behavior and defines template variables       */ -}}
{{- /* that are available in all chezmoi templates.                               */ -}}
{{- /*                                                                            */ -}}
{{- /* Documentation: https://www.chezmoi.io/reference/configuration-file/        */ -}}
{{- /* ========================================================================== */ -}}

{{- /* ========================================================================== */ -}}
{{- /* Operating System Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Detect OS type and Linux distribution to enable OS-specific templates      */ -}}
{{- /* Format: "darwin" for macOS, "linux-<distro>" for Linux variants            */ -}}

{{- $osid := .chezmoi.os -}}

{{- /* For Linux systems, append distribution ID from /etc/os-release */ -}}
{{- if eq .chezmoi.os "linux" -}}
    {{- if hasKey .chezmoi.osRelease "id" -}}
        {{- $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
    {{- else -}}
        {{- $osid = "linux-unknown" -}}
    {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* CPU Architecture Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Detect CPU architecture for platform-specific configurations               */ -}}

{{- $cpuArch        := .chezmoi.arch -}}
{{- $isARM          := false -}}
{{- $isRPi          := false -}}
{{- $isIntel        := false -}}
{{- $isAppleSilicon := false -}}

{{- /* Detect ARM-based processors */ -}}
{{- if or (eq $cpuArch "arm64") (eq $cpuArch "aarch64") (eq $cpuArch "arm") -}}
    {{- $isARM = true -}}
    {{- /* Detect Apple Silicon (macOS on ARM) */ -}}
    {{- if eq .chezmoi.os "darwin" -}}
        {{- $isAppleSilicon = true -}}
    {{- else if eq $osid "linux-debian" -}}
        {{- $isRPi = true -}}
    {{- end -}}
{{- end -}}

{{- /* Detect Intel/AMD x86_64 processors */ -}}
{{- if or (eq $cpuArch "amd64") (eq $cpuArch "x86_64") -}}
    {{- $isIntel = true -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Package Manager Detection                                                  */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Determine the primary package manager based on detected OS                 */ -}}

{{- $packageManager := "unknown" -}}
{{- if eq .chezmoi.os "darwin" -}}
    {{- $packageManager = "brew" -}}
{{- else if eq .chezmoi.os "linux" -}}
    {{- if or (eq $osid "linux-arch") (eq $osid "linux-manjaro") -}}
        {{- $packageManager = "pacman" -}}
    {{- else if or (eq $osid "linux-debian") (eq $osid "linux-ubuntu") (eq $osid "linux-pop") -}}
        {{- $packageManager = "apt" -}}
    {{- else if or (eq $osid "linux-fedora") (eq $osid "linux-rhel") (eq $osid "linux-centos") -}}
        {{- $packageManager = "dnf" -}}
    {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Machine Type                                                               */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Auto-inferred from OS/distro; no prompt required                           */ -}}
{{- /* Values: workstation | terminal                                             */ -}}

{{- $machine := "terminal" -}}
{{- if eq .chezmoi.os "darwin" -}}
    {{- $machine = "workstation" -}}
{{- else if eq $osid "linux-arch" -}}
    {{- $machine = "workstation" -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* User Configuration                                                         */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Personal information used in templates (e.g., git config)                  */ -}}

{{- $email  := "ing.norville@proton.me" -}}
{{- $name   := "Norville" -}}

{{- /* ========================================================================== */ -}}
{{- /* Required Package Lists                                                     */ -}}
{{- /* ========================================================================== */ -}}
{{- /* All package governance lives here. Scripts consume these via {{ range }}.  */ -}}

{{- $core    := list "bat" "btop" "curl" "fzf" "git" "git-delta" "ripgrep" "starship" "vim" "wget" "zoxide" "zsh" -}}
{{- $pacman  := list "base-devel" "eza" "fd" "gnupg" "lazygit" "neovim" "tree-sitter" "ttf-jetbrains-mono" "ttf-jetbrains-mono-nerd" -}}
{{- $aur     := list "bat-extras" "fresh-editor-bin" -}}
{{- $apt     := list "build-essential" "fd-find" "gpg" "tree-sitter-cli" -}}
{{- $dnf     := list "@development-tools" "bat-extras" "eza" "fd-find" "gnupg2" "lazygit" "neovim" "python3-neovim" -}}
{{- $formula := list "chezmoi" "coreutils" "eza" "fd" "findutils" "fresh-editor" "lazygit" "moreutils" "neovim" "tree-sitter-cli" -}}
{{- $cask    := list "1password" "1password-cli" "brave-browser" "font-jetbrains-mono" "font-jetbrains-mono-nerd-font" "kitty" "logi-options-plus" "moom" "tor-browser" "visual-studio-code" "whatsapp" -}}

{{- /* kitty: Linux workstation only (macOS uses brewCasks) */ -}}
{{- if and (ne $packageManager "brew") (eq $machine "workstation") -}}
    {{- $core = append $core "kitty" -}}
{{- end -}}

{{- /* terminal: strip GUI/heavy tools not installed on minimal systems */ -}}
{{- if eq $machine "terminal" -}}
    {{- $core = without $core "btop" "ripgrep" -}}
    {{- $apt  = without $apt "fd-find" "tree-sitter-cli" -}}
    {{- $dnf  = without $dnf "fd-find" "lazygit" "neovim" "python3-neovim" -}}
{{- else -}}
    {{- /* workstation: strip vim (neovim installed instead) */ -}}
    {{- $core = without $core "vim" -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Editor / Merge Commands                                                    */ -}}
{{- /* ========================================================================== */ -}}

{{- $mergeCmd := "vimdiff" -}}
{{- $editCmd  := "vim" -}}
{{- if eq $machine "workstation" -}}
    {{- $mergeCmd = "nvim" -}}
    {{- $editCmd  = "nvim" -}}
{{- end -}}

# =============================================================================
# Chezmoi Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Data Section - Template Variables
# -----------------------------------------------------------------------------
[data]
  # User email address
  email = {{ $email | quote }}

  # User full name
  name = {{ $name | quote }}

  # Operating system identifier (e.g., "darwin", "linux-ubuntu", "linux-fedora")
  osid = {{ $osid | quote }}

  # Machine identifier (e.g., "workstation", "terminal")
  machine = {{ $machine | quote }}

  # CPU architecture (e.g., "amd64", "arm64", "x86_64", "aarch64")
  cpuArch = {{ $cpuArch | quote }}

  # Architecture flags
  isARM           = {{ $isARM }}
  isRPi           = {{ $isRPi }}
  isIntel         = {{ $isIntel }}
  isAppleSilicon  = {{ $isAppleSilicon }}

  # Package manager (e.g., "brew", "apt", "dnf", "pacman")
  packageManager = {{ $packageManager | quote }}

  # Required Package lists
  corePackages    = {{ $core | toJson }}
  pacmanPackages  = {{ $pacman | toJson }}
  aurPackages     = {{ $aur | toJson }}
  aptPackages     = {{ $apt | toJson }}
  dnfPackages     = {{ $dnf | toJson }}
  brewFormulae    = {{ $formula | toJson }}
  brewCasks       = {{ $cask | toJson }}

# -----------------------------------------------------------------------------
# Script Environment Variables
# -----------------------------------------------------------------------------
# Environment variables available to all chezmoi scripts
[scriptEnv]
  # Path to BDB helper functions (relative to source directory)
  HELPERS = "{{ .chezmoi.homeDir }}/.config/bdb/bdb_helpers.sh"

# -----------------------------------------------------------------------------
# Git Configuration
# -----------------------------------------------------------------------------
# Configure how chezmoi interacts with the git repository
[git]
  # Automatically commit changes when applying
  autoCommit = false

  # Automatically push changes after commit
  autoPush = false

# -----------------------------------------------------------------------------
# Diff Configuration
# -----------------------------------------------------------------------------
# Configure diff tool for reviewing changes
[diff]
  # Use external diff tool if available
  pager = "delta"

# -----------------------------------------------------------------------------
# Merge Configuration
# -----------------------------------------------------------------------------
# Configure merge strategy for conflicts
[merge]
  command = {{ $mergeCmd | quote }}
{{- if eq $machine "workstation" }}
  args = ["-d"]
{{- end }}

# -----------------------------------------------------------------------------
# Editor Configuration
# -----------------------------------------------------------------------------
# Default editor for 'chezmoi edit'
[edit]
  command = {{ $editCmd | quote }}
  args = []

# -----------------------------------------------------------------------------
# Template Options
# -----------------------------------------------------------------------------
# Configure template rendering behavior
[template]
  # Template options
  options = ["missingkey=error"]

# -----------------------------------------------------------------------------
# 1Password Configuration
# -----------------------------------------------------------------------------
# Enables onepasswordRead / onepassword* template functions.
# prompt = true: re-prompts for biometric/password auth if the session expires
# instead of erroring out. Requires op CLI and an active account.
[onepassword]
  prompt = true

# =============================================================================
