{{- /* ========================================================================== */ -}}
{{- /* Chezmoi Configuration Template                                             */ -}}
{{- /* ========================================================================== */ -}}
{{- /* This file configures chezmoi behavior and defines template variables       */ -}}
{{- /* that are available in all chezmoi templates.                               */ -}}
{{- /*                                                                            */ -}}
{{- /* Documentation: https://www.chezmoi.io/reference/configuration-file/        */ -}}
{{- /* ========================================================================== */ -}}

{{- /* ========================================================================== */ -}}
{{- /* Operating System Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Format: "darwin" for macOS, "linux-<distro>" for Linux variants            */ -}}
{{- /* Supported: darwin, linux-arch, linux-cachyos, linux-ubuntu,               */ -}}
{{- /*            linux-debian, linux-fedora, linux-rocky                         */ -}}

{{- $osid := .chezmoi.os -}}

{{- if eq .chezmoi.os "linux" -}}
    {{- if hasKey .chezmoi.osRelease "id" -}}
        {{- $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
    {{- else -}}
        {{- $osid = "linux-unknown" -}}
    {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* CPU Architecture Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}

{{- $cpuArch        := .chezmoi.arch -}}
{{- $isARM          := false -}}
{{- $isRPi          := false -}}
{{- $isIntel        := false -}}
{{- $isAppleSilicon := false -}}

{{- if or (eq $cpuArch "arm64") (eq $cpuArch "aarch64") (eq $cpuArch "arm") -}}
    {{- $isARM = true -}}
    {{- if eq .chezmoi.os "darwin" -}}
        {{- $isAppleSilicon = true -}}
    {{- else if eq $osid "linux-debian" -}}
        {{- $isRPi = true -}}
    {{- end -}}
{{- end -}}

{{- if or (eq $cpuArch "amd64") (eq $cpuArch "x86_64") -}}
    {{- $isIntel = true -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Package Manager Detection                                                  */ -}}
{{- /* ========================================================================== */ -}}
{{- /* darwin         → brew                                                      */ -}}
{{- /* arch, cachyos  → pacman                                                    */ -}}
{{- /* ubuntu, debian → apt                                                       */ -}}
{{- /* fedora, rocky  → dnf                                                       */ -}}

{{- $packageManager := "unknown" -}}
{{- if eq .chezmoi.os "darwin" -}}
    {{- $packageManager = "brew" -}}
{{- else if eq .chezmoi.os "linux" -}}
    {{- if or (eq $osid "linux-arch") (eq $osid "linux-cachyos") -}}
        {{- $packageManager = "pacman" -}}
    {{- else if or (eq $osid "linux-debian") (eq $osid "linux-ubuntu") -}}
        {{- $packageManager = "apt" -}}
    {{- else if or (eq $osid "linux-fedora") (eq $osid "linux-rocky") -}}
        {{- $packageManager = "dnf" -}}
    {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Machine Type Detection                                                     */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Values: workstation | terminal | server                                    */ -}}
{{- /*                                                                            */ -}}
{{- /* darwin, arch, cachyos, fedora → always workstation (no prompt)            */ -}}
{{- /* ubuntu → workstation if a graphical session is detected; else prompt      */ -}}
{{- /* debian, rocky → always prompt (never workstation)                         */ -}}

{{- $machine := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
    {{- $machine = "workstation" -}}
{{- else if or (eq $osid "linux-arch") (eq $osid "linux-cachyos") (eq $osid "linux-fedora") -}}
    {{- $machine = "workstation" -}}
{{- else if eq $osid "linux-ubuntu" -}}
    {{- if or (eq (env "XDG_SESSION_TYPE") "x11")
               (eq (env "XDG_SESSION_TYPE") "wayland")
               (ne (env "DISPLAY") "")
               (ne (env "WAYLAND_DISPLAY") "") -}}
        {{- $machine = "workstation" -}}
    {{- else -}}
        {{- $machine = promptStringOnce . "machine" "Machine type [terminal/server]" -}}
    {{- end -}}
{{- else if or (eq $osid "linux-debian") (eq $osid "linux-rocky") -}}
    {{- $machine = promptStringOnce . "machine" "Machine type [terminal/server]" -}}
{{- else -}}
    {{- $machine = "terminal" -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Desktop Environment Detection                                              */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Lowercased XDG_CURRENT_DESKTOP. Empty on headless systems or bare WMs.    */ -}}
{{- /* Ubuntu sets "ubuntu:GNOME"; use contains "gnome" rather than eq.          */ -}}

{{- $desktop := env "XDG_CURRENT_DESKTOP" | lower -}}

{{- /* ========================================================================== */ -}}
{{- /* User Configuration                                                         */ -}}
{{- /* ========================================================================== */ -}}

{{- $email  := "ing.norville@proton.me" -}}
{{- $name   := "Norville" -}}

{{- /* ========================================================================== */ -}}
{{- /* Package Lists                                                              */ -}}
{{- /* ========================================================================== */ -}}
{{- /* All lists defined for workstation. Terminal strips W-only packages.        */ -}}
{{- /* Server replaces lists with S:Y packages only.                              */ -}}
{{- /* Canonical source: dotfiles-overhaul-spec.md §5                            */ -}}

{{- /* ---- Homebrew Formulae (macOS workstation) ---- */ -}}
{{- $brewFormulae := list
    "bat" "bat-extras" "btop" "chezmoi" "coreutils" "curl" "eza"
    "fd" "ffmpeg-full" "findutils" "fzf" "git" "git-delta"
    "imagemagick-full" "jq" "lazygit" "moreutils" "neovim" "poppler"
    "resvg" "ripgrep" "sevenzip" "starship" "tree-sitter-cli"
    "vim" "wget" "yazi" "zoxide" "zsh" -}}

{{- /* ---- Homebrew Casks (macOS workstation) ---- */ -}}
{{- $brewCasks := list
    "brave-browser"
    "font-jetbrains-mono" "font-jetbrains-mono-nerd-font" "font-symbols-only-nerd-font"
    "kitty" "logi-options-plus" "moom" "whatsapp" "zed" -}}

{{- /* ---- APT packages (Ubuntu / Debian) ---- */ -}}
{{- /* brave-browser and zed require external repo setup in 00-install-core.     */ -}}
{{- /* yazi, lazygit, nvim (neovim) are installed via snap — see $snapPackages.  */ -}}
{{- $aptPackages := list
    "bat" "brave-browser" "btop" "build-essential" "curl"
    "eza" "fd-find" "fzf" "git" "git-delta" "gpg"
    "kitty" "ripgrep" "starship" "tree-sitter-cli"
    "vim" "wget" "zed" "zoxide" "zsh" -}}

{{- /* ---- Snap packages (Ubuntu / Debian) ---- */ -}}
{{- /* All installed with --classic confinement.                                  */ -}}
{{- $snapPackages := list "chezmoi" "lazygit" "nvim" "yazi" -}}

{{- /* ---- Pacman packages (Arch / CachyOS — always workstation) ---- */ -}}
{{- $pacmanPackages := list
    "7zip" "base-devel" "bat" "bat-extras" "btop" "chezmoi" "curl"
    "eza" "fd" "ffmpeg" "fzf" "git" "git-delta" "gnupg"
    "imagemagick" "jq" "kitty" "lazygit" "neovim" "poppler" "resvg"
    "ripgrep" "starship" "tree-sitter" "ttf-jetbrains-mono" "ttf-jetbrains-mono-nerd"
    "vim" "wget" "yazi" "zed" "zoxide" "zsh" -}}

{{- /* ---- AUR packages (Arch / CachyOS — always workstation) ---- */ -}}
{{- $aurPackages := list "brave-bin" -}}

{{- /* ---- DNF packages (Fedora / Rocky) ---- */ -}}
{{- /* brave-browser, zed, yazi require external repo/COPR setup in script.      */ -}}
{{- $dnfPackages := list
    "@development-tools" "bat" "bat-extras" "brave-browser" "btop" "chezmoi"
    "curl" "eza" "fd-find" "fzf" "git" "git-delta" "gnupg2"
    "kitty" "lazygit" "neovim" "python3-neovim" "ripgrep" "starship"
    "vim" "wget" "yazi" "zed" "zoxide" "zsh" -}}

{{- /* ---- GNOME Linux workstation extras ---- */ -}}
{{- if and (eq $machine "workstation") (eq .chezmoi.os "linux") (contains "gnome" $desktop) -}}
    {{- $pacmanPackages = append $pacmanPackages "darkman" "xdg-desktop-portal-gtk" -}}
    {{- $aptPackages    = append $aptPackages    "darkman" "xdg-desktop-portal-gtk" -}}
    {{- $dnfPackages    = append $dnfPackages    "darkman" "xdg-desktop-portal-gtk" -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Machine-Type Filtering                                                     */ -}}
{{- /* ========================================================================== */ -}}
{{- /* terminal: strip W-only packages (W:Y T:N in canonical table)               */ -}}
{{- /* server:   replace lists with S:Y packages only                             */ -}}

{{- if eq $machine "terminal" -}}
    {{- $aptPackages  = without $aptPackages  "brave-browser" "kitty" "zed" -}}
    {{- $snapPackages = without $snapPackages  "yazi" -}}
    {{- $dnfPackages  = without $dnfPackages  "brave-browser" "kitty" "yazi" "zed" -}}
    {{- /* pacman/aur: arch/cachyos are always workstation — no trimming needed */ -}}
{{- else if eq $machine "server" -}}
    {{- $aptPackages    = list "curl" "git" "vim" "wget" -}}
    {{- $snapPackages   = list "chezmoi" -}}
    {{- $dnfPackages    = list "chezmoi" "curl" "git" "vim" "wget" -}}
    {{- $pacmanPackages = list -}}
    {{- $aurPackages    = list -}}
    {{- $brewFormulae   = list -}}
    {{- $brewCasks      = list -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Editor / Merge Commands                                                    */ -}}
{{- /* ========================================================================== */ -}}
{{- /* server has no neovim (S:N); workstation and terminal both have nvim (T:Y). */ -}}

{{- $mergeCmd := "vimdiff" -}}
{{- $editCmd  := "vim" -}}
{{- if ne $machine "server" -}}
    {{- $mergeCmd = "nvim" -}}
    {{- $editCmd  = "nvim" -}}
{{- end -}}

# =============================================================================
# Chezmoi Configuration
# =============================================================================

[data]
  email          = {{ $email          | quote }}
  name           = {{ $name           | quote }}
  osid           = {{ $osid           | quote }}
  machine        = {{ $machine        | quote }}
  desktop        = {{ $desktop        | quote }}
  cpuArch        = {{ $cpuArch        | quote }}
  isARM          = {{ $isARM }}
  isRPi          = {{ $isRPi }}
  isIntel        = {{ $isIntel }}
  isAppleSilicon = {{ $isAppleSilicon }}
  packageManager = {{ $packageManager | quote }}

  brewFormulae   = {{ $brewFormulae   | toJson }}
  brewCasks      = {{ $brewCasks      | toJson }}
  aptPackages    = {{ $aptPackages    | toJson }}
  snapPackages   = {{ $snapPackages   | toJson }}
  pacmanPackages = {{ $pacmanPackages | toJson }}
  aurPackages    = {{ $aurPackages    | toJson }}
  dnfPackages    = {{ $dnfPackages    | toJson }}

[scriptEnv]
  HELPERS = "{{ .chezmoi.homeDir }}/.config/bdb/bdb_helpers.sh"

[git]
  autoCommit = false
  autoPush   = false

[diff]
  pager = "delta"

[merge]
  command = {{ $mergeCmd | quote }}
{{- if ne $machine "server" }}
  args = ["-d"]
{{- end }}

[edit]
  command = {{ $editCmd | quote }}
  args    = []

[template]
  options = ["missingkey=error"]

[onepassword]
  prompt = true
