## Color scheme
include             Tokyo-Night-Moon.conf
background_opacity  0.95

## Fonts
{{ if eq .chezmoi.os "linux" -}}
# Linux uses the plain "Nerd Font" variant at 12pt (HiDPI handled by compositor).
font_family       family='JetBrainsMono Nerd Font' style=Regular
font_size         12.0
{{ else if eq .chezmoi.os "darwin" -}}
# macOS uses the "Nerd Font Mono" variant at 15pt (Retina display scaling).
font_family       family='JetBrainsMono Nerd Font Mono' style=Regular
font_size         15.0
{{ end -}}
bold_font         auto
bold_italic_font  auto
disable_ligatures always
font_features     none
italic_font       auto

## Text cursor customization
cursor_shape            block
cursor_shape_unfocused  hollow

## Scrollback
scrollback_lines              5000
scrollback_pager_history_size 10
scrollbar                     never

## Mouse
strip_trailing_spaces smart

## Window layout
enabled_layouts           tall:bias=50;full_size=1;mirrored=false
remember_window_size      yes
remember_window_position  yes
window_padding_width      4
window_border_width       2
hide_window_decorations   titlebar-only

## Tab bar
tab_bar_min_tabs  1
tab_bar_edge      bottom
tab_bar_style     custom

## Advanced
shell_integration no-cursor

## Startup
# run fastfetch in the first window at launch, then drop to the shell (see startup.session)
startup_session startup.session

## Keyboard shortcuts
# close all SSH connections shared by kitten ssh (e.g. after a network change)
map ctrl+alt+super+k  close_shared_ssh_connections

## Sessions
# save window state to a session file; prompts for name, default dir: ~/.config/kitty/sessions/
map f1 save_as_session --use-foreground-process --base-dir ~/.config/kitty/sessions

# pick a session from ~/.config/kitty/sessions/ and open it in a new tab
# (goto_session focuses an already-open session or creates a new tab from the file)
map f4 goto_session ~/.config/kitty/sessions
