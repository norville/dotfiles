{{- /* --------------------------------------------------------------------- */ -}}
{{- /* OS accent color вҖ” resolved by chezmoi at `apply` time and baked in.    */ -}}
{{- /* Sets $os_bg so the [os] segment background matches the live starship   */ -}}
{{- /* os symbol. Colors mirror the map in [os.symbols] below вҖ” keep in sync. */ -}}
{{- /* Order: macOS, then Windows, then Linux distro (by os-release id);      */ -}}
{{- /* anything unlisted falls back to the $os_bg default ("black").          */ -}}
{{- /* --------------------------------------------------------------------- */ -}}
{{- $os_bg := "black" -}}
{{- $distro := dict "arch" "blue2" "cachyos" "teal" "debian" "magenta2" "fedora" "blue1" "rocky" "green2" "ubuntu" "orange" -}}
{{- if eq .chezmoi.os "darwin" }}
  {{- $os_bg = "term_white_bright" }}
{{- else if eq .chezmoi.os "windows" }}
  {{- $os_bg = "blue0" }}
{{- else if hasKey $distro .chezmoi.osRelease.id }}
  {{- $os_bg = index $distro .chezmoi.osRelease.id }}
{{- end -}}
palette = "tokyonight_moon"

# в•җв•җв•җ Prompt layout в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# Line 1: в•ӯ os user host dir git-branch/commit git-status  вҶ’$fillвҶ’  runtimes package duration status
# Line 2: в”Ӯ
# Line 3: в•° shlvl character
format = """
[в•ӯ](fg:ui_bg_highlight)\
$os\
$username\
$hostname\
$directory\
$git_branch\
$git_commit\
$git_status\
$fill\
$c\
$conda\
$golang\
$java\
$lua\
$nodejs\
$python\
$ruby\
$rust\
$terraform\
$package\
$cmd_duration\
$status\
$line_break\
[в”Ӯ](fg:ui_bg_highlight)\
$line_break\
[в•°](fg:ui_bg_highlight)\
$shlvl\
$character"""

# в”Җв”Җ os В· bg per-OS, resolved by the $os_bg template above в”Җв”Җ distro icon; opens the bar в”Җв”Җ
[os]
disabled  = false
style     = "bg:{{ $os_bg }} fg:ui_bg bold"
format    = "[оӮ¶](fg:{{ $os_bg }})[$symbol ]($style)[оӮё](bg:ui_bg_highlight fg:{{ $os_bg }})"

# Icon per OS; the trailing note is the bg color it selects via the $distro map above.
[os.symbols]
Arch        = "у°ЈҮ"   # blue2
CachyOS     = "CпҢІ"  # teal
Debian      = "у°Јҡ"   # magenta2
Fedora      = "у°Јӣ"   # blue1
Macos       = "у°Җө"   # term_white_bright
RockyLinux  = "пҢ«"   # green2
Ubuntu      = "у°•Ҳ"   # orange
Windows     = "оңҸ"   # blue0

# в”Җв”Җ username В· yellow в”Җв”Җ user icon + name; starts the ui_bg_highlight bar body в”Җв”Җ
[username]
style_user  = "bg:ui_bg_highlight fg:term_yellow bold"
format      = "[оӮё пӢҖ оӮҫ](bg:term_yellow fg:ui_bg_highlight)[ $user]($style)"

# в”Җв”Җ hostname В· yellow в”Җв”Җ @host, continuing the username segment в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[hostname]
style   = "bg:ui_bg_highlight fg:term_yellow bold"
format  = "[@$hostname ]($style)"

# в”Җв”Җ directory В· cyan в”Җв”Җ folder icon + path, truncated to the repo root в”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[directory]
read_only           = "у°Ңҫ"
truncation_length   = 5
truncation_symbol   = "вҖҰ/"
truncate_to_repo    = true
style               = "bg:ui_bg_highlight fg:term_cyan bold"
format              = "[оӮё п„” оӮҫ](bg:term_cyan fg:ui_bg_highlight)[ $path $read_only ]($style)"

# в”Җв”Җ git_branch В· magenta в”Җв”Җ branch icon + name в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[git_branch]
symbol  = "пҗҳ"
style   = "bg:ui_bg_highlight fg:term_magenta bold"
format  = "[оӮё $symbol оӮҫ](bg:term_magenta fg:ui_bg_highlight)[ $branch(:$remote_branch)]($style)"

# в”Җв”Җ git_commit В· magenta в”Җв”Җ @hash / tag, continuing the git_branch segment в”Җв”Җв”Җ
[git_commit]
only_detached       = false  # show hash on normal branches too, not just detached HEAD
tag_disabled        = false
tag_max_candidates  = 1
style               = "bg:ui_bg_highlight fg:term_magenta bold"
format              = "[@$hash$tag ]($style)"

# в”Җв”Җ git_status В· per-state bubbles в”Җв”Җ one colored badge per change type в”Җв”Җв”Җв”Җв”Җв”Җ
[git_status]
ahead       = "[оӮҫ](bg:ui_bg_highlight fg:git_change)[ пӮӘ ${count} ](bg:git_change fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_change)"
behind      = "[оӮҫ](bg:ui_bg_highlight fg:git_change)[ пӮ« ${count} ](bg:git_change fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_change)"
conflicted  = "[оӮҫ](bg:ui_bg_highlight fg:git_delete)[ у°үҖ ${count} ](bg:git_delete fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_delete)"
deleted     = "[оӮҫ](bg:ui_bg_highlight fg:git_delete)[ у°Ҷҙ ${count} ](bg:git_delete fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_delete)"
diverged    = "[оӮҫ](bg:ui_bg_highlight fg:git_delete)[ у°ғ» ${count} ](bg:git_delete fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_delete)"
modified    = "[оӮҫ](bg:ui_bg_highlight fg:git_change)[ у°ӨҖ ${count} ](bg:git_change fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_change)"
renamed     = "[оӮҫ](bg:ui_bg_highlight fg:git_change)[ пҒҺ ${count} ](bg:git_change fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_change)"
staged      = "[оӮҫ](bg:ui_bg_highlight fg:git_add)[ пҒ• ${count} ](bg:git_add fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_add)"
stashed     = "[оӮҫ](bg:ui_bg_highlight fg:git_change)[ у°Ҹ” ${count} ](bg:git_change fg:ui_bg)[оӮё](bg:ui_bg_highlight fg:git_change)"
untracked   = "[оӮҫ](bg:ui_bg_highlight fg:git_ignore)[ уұ§Ҡ ${count} ](bg:git_ignore)[оӮё](bg:ui_bg_highlight fg:git_ignore)"
style       = "bold"
format      = "[$all_status$ahead_behind]($style)"

# в”Җв”Җ fill В· stretches the bar bg and pushes the modules after it to the right в”Җв”Җ
[fill]
symbol  = " "
style   = "bg:ui_bg_highlight"

# в•җв•җв•җ Right side В· runtime bar (bg:ui_bg_highlight, italic) в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# Language runtimes & tooling вҖ” each module shows only inside a matching project,
# colored per language; the thin powerline separators are baked into each format.
# Covers: c conda golang java lua nodejs python ruby rust terraform.
[c]
symbol  = "оҳһ"
style   = "bg:ui_bg_highlight fg:blue7 bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[conda]
ignore_base = false  # default hides "base" env; keep it visible
symbol      = "оң•"
style       = "bg:ui_bg_highlight fg:green bold italic"
format      = "[оӮұ $symbol $environment ]($style)"

[golang]
symbol  = "у°ҹ“"
style   = "bg:ui_bg_highlight fg:cyan bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[java]
symbol  = "оҷӯ"
style   = "bg:ui_bg_highlight fg:orange bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[lua]
symbol  = "оҳ "
style   = "bg:ui_bg_highlight fg:blue bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[nodejs]
symbol  = "оҙҚ"
style   = "bg:ui_bg_highlight fg:green1 bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[python]
pyenv_prefix  = "venv "
python_binary = ["./venv/bin/python", "python", "python3", "python2"]  # local venv detected without activation
symbol        = "оҲө"
style         = "bg:ui_bg_highlight fg:yellow bold italic"
format        = "[оӮұ $symbol $version(\\($virtualenv\\)) ]($style)"

[ruby]
symbol  = "оһ‘"
style   = "bg:ui_bg_highlight fg:red bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[rust]
symbol  = "уұҳ—"
style   = "bg:ui_bg_highlight fg:red1 bold italic"
format  = "[оӮұ $symbol $version ]($style)"

[terraform]
symbol  = "оўҪ"
style   = "bg:ui_bg_highlight fg:blue1 bold italic"
format  = "[оӮұ $symbol $version:$workspace ]($style)"

# в”Җв”Җ package В· white в”Җв”Җ version read from the manifest in the cwd в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[package]
symbol  = "о¬©"
style   = "bg:ui_bg_highlight fg:term_white bold italic"
format  = "[оӮұ $symbol $version:$workspace ]($style)"

# в”Җв”Җ cmd_duration В· orange в”Җв”Җ wall-clock time of the last command (вүҘ min_time) в”Җ
[cmd_duration]
min_time  = 500
style     = "bg:ui_bg_highlight fg:orange bold italic"
format    = "[оӮұ уұҰҹ $duration ]($style)"

# в”Җв”Җ status В· red on failure / green on success в”Җв”Җ exit code; its cap closes the bar в”Җв”Җ
[status]
disabled        = false
success_symbol  = " " # required to render module
style           = "bg:ui_bg_highlight fg:red bold italic"
success_style   = "bg:ui_bg_highlight fg:green1 bold italic"
format          = "[оӮұ у°ҝ… $status$signal_number( $common_meaning$signal_name$maybe_int)]($style)[оӮҙ](bg:ui_bg fg:ui_bg_highlight)"

# в”Җв”Җ shlvl В· line 3 в”Җв”Җ one вқҜ per extra shell nesting level в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
[shlvl]
disabled      = false
repeat        = true
repeat_offset = 1  # shows shlvl-1 symbols: silent at level 1, one вқҜ at level 2, etc.
symbol        = "вқҜ"
style         = "fg:ui_bg_highlight"
format        = "[$symbol]($style)"

[palettes.tokyonight_moon]

