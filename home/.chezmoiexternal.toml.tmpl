# =============================================================================
# Chezmoi External Resources
# =============================================================================
# Files chezmoi downloads and keeps up to date itself (themes, fonts) —
# nothing here is tracked in git; each entry re-downloads after its
# refreshPeriod expires ("720h" = monthly).
#
# Documentation: https://www.chezmoi.io/reference/special-files-and-directories/chezmoiexternal-format/
# =============================================================================

# -----------------------------------------------------------------------------
# Color Schemes and Themes
# -----------------------------------------------------------------------------
# Download and manage color schemes for various applications

# Tokyo Night theme for bat (syntax highlighting)
[".config/bat/themes/tokyonight_moon.tmTheme"]
  type = "file"
  url = "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/sublime/tokyonight_moon.tmTheme"
  refreshPeriod = "720h"
  executable = false

# Tokyo Night theme for eza (ls replacement)
[".config/eza/theme.yml"]
  type = "file"
  url = "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/eza/tokyonight_moon.yml"
  refreshPeriod = "720h"
  executable = false

# Tokyo Night theme for btop (system monitor)
[".config/btop/themes/tokyonight_moon.theme"]
  type = "file"
  url = "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/btop/tokyonight_moon.theme"
  refreshPeriod = "720h"
  executable = false

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Workstation-only themes                                              */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .machine "workstation" }}
# Tokyo Night theme for Zed (workstation only)
# Provides: Tokyo Night, Tokyo Night Light, Tokyo Night Storm, Tokyo Night Moon
[".config/zed/themes/tokyo-night.json"]
  type = "file"
  url = "https://raw.githubusercontent.com/ssaunderss/zed-tokyo-night/main/themes/tokyo-night.json"
  refreshPeriod = "720h"
  executable = false

# -----------------------------------------------------------------------------
# Wallpapers (workstation only)
# -----------------------------------------------------------------------------
# Named by function. The desktop wallpapers live in ~/Pictures/Wallpapers, which
# noctalia scans wholesale (dot_config/noctalia/settings.json); its "primary"
# favorite references primary.jpg by absolute path, so renaming breaks it.
#
# The login wallpaper is deliberately NOT in Pictures — that would drop it into
# noctalia's desktop rotation. It targets the SDDM theme's source folder,
# replacing the git-tracked background.jpg (now .gitignored);
# run_onchange_after_06-install-sddm deploys it to /usr/share from there, and
# Main.qml hardcodes the name background.jpg. The target path is derived from
# .chezmoi.sourceDir so it survives a different username; it assumes the default
# source dir under ~ (where chezmoi clones it).
#
# refreshPeriod is a year rather than the 720h used above: these are immutable
# published images, so a monthly re-fetch buys nothing and only widens the window
# for a dead upstream URL to fail `chezmoi apply`.
#
# The unsplash `w=` parameter selects a server-side resize: primary is pinned to
# 2560 to match the display, secondary is portrait and pinned to 1920.

# Primary desktop wallpaper — noctalia default
["Pictures/Wallpapers/primary.jpg"]
  type = "file"
  url = "https://unsplash.com/photos/5-GNa303REg/download?force=true&w=2560"
  refreshPeriod = "8760h"
  executable = false

# Secondary desktop wallpaper (portrait monitor)
["Pictures/Wallpapers/secondary.jpg"]
  type = "file"
  url = "https://unsplash.com/photos/wIZpOCdTb8I/download?force=true&w=1920"
  refreshPeriod = "8760h"
  executable = false

# Browser new-tab background
["Pictures/Wallpapers/browser.jpg"]
  type = "file"
  url = "https://wallpapercave.com/download/aesthetic-super-red-wallpapers-wp4866024"
  refreshPeriod = "8760h"
  executable = false

# Login screen (SDDM) — deployed to /usr/share by 06-install-sddm; see note above
["{{ .chezmoi.sourceDir | trimPrefix .chezmoi.homeDir | trimPrefix "/" }}/sddm/themes/tokyonight-moon/background.jpg"]
  type = "file"
  url = "https://wallpapercave.com/download/tokyo-aesthetic-wallpapers-wp6570018"
  refreshPeriod = "8760h"
  executable = false
{{- end }}

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Linux-specific external resources                                    */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .chezmoi.os "linux" }}
# -----------------------------------------------------------------------------
# Fonts (apt/dnf only)
# -----------------------------------------------------------------------------
# Debian/Ubuntu/Fedora repos lack Nerd Fonts packages, so the font files are
# deployed here. pacman and brew ship dedicated font packages instead — on
# those platforms this section renders empty and packages own the fonts.
  {{- if or (eq .packageManager "apt") (eq .packageManager "dnf") }}

# JetBrains Mono — official release (non-patched)
[".local/share/fonts/JetBrainsMono/official"]
  type = "archive"
  url = "https://github.com/JetBrains/JetBrainsMono/releases/download/v2.304/JetBrainsMono-2.304.zip"
  stripComponents = 2             # Ignore top two directories
  include = ["fonts/ttf/*.ttf"]   # Only include TTF files
  refreshPeriod = "720h"

# JetBrains Mono Nerd Font — patched with Nerd Font icons
[".local/share/fonts/JetBrainsMono/nerd"]
  type = "archive"
  url = "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz"
  stripComponents = 0     # Keep directory structure
  include = ["*.ttf"]     # Only include TTF files
  refreshPeriod = "720h"

  {{- end }}
{{- end }}
