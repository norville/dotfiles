{{- /* ========================================================================== */ -}}
{{- /* Chezmoi Configuration Template                                             */ -}}
{{- /* ========================================================================== */ -}}
{{- /* This file configures chezmoi behavior and defines template variables       */ -}}
{{- /* that are available in all chezmoi templates.                               */ -}}
{{- /*                                                                            */ -}}
{{- /* Package data lives in .chezmoidata.toml (loaded by chezmoi automatically,  */ -}}
{{- /* but NOT available here during `chezmoi init` on a fresh machine).          */ -}}
{{- /* Scripts and brewfile.tmpl filter .package directly at render time.         */ -}}
{{- /*                                                                            */ -}}
{{- /* Documentation: https://www.chezmoi.io/reference/configuration-file/        */ -}}
{{- /* ========================================================================== */ -}}

{{- /* ========================================================================== */ -}}
{{- /* Operating System Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Format: "darwin" for macOS, "linux-<distro>" for Linux variants            */ -}}
{{- /* Supported: darwin, linux-arch, linux-cachyos, linux-ubuntu,                */ -}}
{{- /*            linux-debian, linux-fedora, linux-rocky                         */ -}}

{{- $osid := .chezmoi.os -}}

{{- if eq .chezmoi.os "linux" -}}
  {{- if hasKey .chezmoi.osRelease "id" -}}
    {{- $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
  {{- else -}}
    {{- $osid = "linux-unknown" -}}
  {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* CPU Architecture Detection                                                 */ -}}
{{- /* ========================================================================== */ -}}

{{- $cpuArch        := .chezmoi.arch -}}
{{- $isARM          := false -}}
{{- $isRPi          := false -}}
{{- $isIntel        := false -}}
{{- $isAppleSilicon := false -}}

{{- if or (eq $cpuArch "arm64") (eq $cpuArch "aarch64") (eq $cpuArch "arm") -}}
  {{- $isARM = true -}}
  {{- if eq .chezmoi.os "darwin" -}}
    {{- $isAppleSilicon = true -}}
  {{- else if eq $osid "linux-debian" -}}
    {{- $isRPi = true -}}
  {{- end -}}
{{- end -}}

{{- if or (eq $cpuArch "amd64") (eq $cpuArch "x86_64") -}}
  {{- $isIntel = true -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Package Manager Detection                                                  */ -}}
{{- /* ========================================================================== */ -}}
{{- /* darwin         → brew                                                      */ -}}
{{- /* arch, cachyos  → pacman                                                    */ -}}
{{- /* ubuntu, debian → apt                                                       */ -}}
{{- /* fedora, rocky  → dnf                                                       */ -}}

{{- $packageManager := "unknown" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $packageManager = "brew" -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- if or (eq $osid "linux-arch") (eq $osid "linux-cachyos") -}}
    {{- $packageManager = "pacman" -}}
  {{- else if or (eq $osid "linux-debian") (eq $osid "linux-ubuntu") -}}
    {{- $packageManager = "apt" -}}
  {{- else if or (eq $osid "linux-fedora") (eq $osid "linux-rocky") -}}
    {{- $packageManager = "dnf" -}}
  {{- end -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Machine Type Detection                                                     */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Values: workstation | terminal | server                                    */ -}}
{{- /*                                                                            */ -}}
{{- /* darwin, arch, cachyos, fedora → always workstation (no prompt)             */ -}}
{{- /* ubuntu → workstation if a graphical session is detected; else prompt       */ -}}
{{- /* debian, rocky → always prompt (never workstation)                          */ -}}

{{- $machine := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $machine = "workstation" -}}
{{- else if or (eq $osid "linux-arch") (eq $osid "linux-cachyos") (eq $osid "linux-fedora") -}}
  {{- $machine = "workstation" -}}
{{- else if eq $osid "linux-ubuntu" -}}
  {{- if or (eq (env "XDG_SESSION_TYPE") "x11")
            (eq (env "XDG_SESSION_TYPE") "wayland")
            (ne (env "DISPLAY") "")
            (ne (env "WAYLAND_DISPLAY") "") -}}
    {{- $machine = "workstation" -}}
  {{- else -}}
    {{- $machine = promptStringOnce . "machine" "Machine type [terminal/server]" -}}
  {{- end -}}
{{- else if or (eq $osid "linux-debian") (eq $osid "linux-rocky") -}}
  {{- $machine = promptStringOnce . "machine" "Machine type [terminal/server]" -}}
{{- else -}}
  {{- $machine = "terminal" -}}
{{- end -}}

{{- /* Only the two prompt answers can be invalid; auto-detection always yields   */ -}}
{{- /* workstation or terminal. Reject any other entry (typos) so init fails fast */ -}}
{{- /* rather than producing a machine with no matching deployment scope.         */ -}}
{{- if not (has $machine (list "workstation" "terminal" "server")) -}}
  {{- fail (printf "invalid machine type %q — must be 'terminal' or 'server'" $machine) -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Desktop Environment Detection                                              */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Intentionally NOT exported as a data var. This file re-renders only on     */ -}}
{{- /* `chezmoi init`, so a captured value would go stale and (with               */ -}}
{{- /* missingkey=error) break `apply` on any machine that hasn't re-init'd.      */ -}}
{{- /* Templates that need GNOME detection read env "XDG_CURRENT_DESKTOP" | lower */ -}}
{{- /* live at apply time instead — see .chezmoiignore and 00/07/08 scripts.      */ -}}

{{- /* ========================================================================== */ -}}
{{- /* User Configuration                                                         */ -}}
{{- /* ========================================================================== */ -}}

{{- $email  := "ing.norville@proton.me" -}}
{{- $name   := "Norville" -}}

{{- /* ========================================================================== */ -}}
{{- /* Editor / Merge Commands                                                    */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Neovim is installed on workstation and terminal machines; servers only     */ -}}
{{- /* get plain vim, so they fall back to vim/vimdiff.                           */ -}}

{{- $mergeCmd := "vimdiff" -}}
{{- $editCmd  := "vim" -}}
{{- if ne $machine "server" -}}
  {{- $mergeCmd = "nvim" -}}
  {{- $editCmd  = "nvim" -}}
{{- end -}}

# =============================================================================
# Chezmoi Configuration
# =============================================================================

[data]
  email          = {{ $email          | quote }}
  name           = {{ $name           | quote }}
  osid           = {{ $osid           | quote }}
  machine        = {{ $machine        | quote }}
  cpuArch        = {{ $cpuArch        | quote }}
  isARM          = {{ $isARM }}
  isRPi          = {{ $isRPi }}
  isIntel        = {{ $isIntel }}
  isAppleSilicon = {{ $isAppleSilicon }}
  packageManager = {{ $packageManager | quote }}

[scriptEnv]
  HELPERS = "{{ .chezmoi.homeDir }}/.config/bdb/bdb_helpers.sh"

# Full system/toolchain upgrade runs ONLY after `chezmoi update`.
# (run_after_ scripts would fire on every `chezmoi apply` — chezmoi has no
# update-only script class, so this lives in a post-update hook instead.)
[hooks.update.post]
  command = "{{ .chezmoi.homeDir }}/.config/bdb/bdb_update.sh"

[git]
  autoCommit = false
  autoPush   = false

[diff]
  pager = "delta"

[merge]
  command = {{ $mergeCmd | quote }}
{{- if ne $machine "server" }}
  args = ["-d"]
{{- end }}

[edit]
  command = {{ $editCmd | quote }}
  args    = []

[template]
  options = ["missingkey=error"]

[onepassword]
  prompt = true
