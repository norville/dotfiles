#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Install Visual Studio Code
# =============================================================================
# Prompts for and installs VS Code. Workstation only.
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_03-install-vscode.sh.tmpl
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
source "${HELPERS}"

bdb_script_init "${BASH_SOURCE[0]}"

bdb_begin_section "Visual Studio Code Installation"

{{- if ne .machine "workstation" }}
bdb_warn "Skipping VS Code — workstation machines only"
bdb_end_section
exit 0
{{- end }}

if bdb_has_cmd "code"; then
    bdb_success "Visual Studio Code already installed"
    bdb_end_section
    exit 0
fi

if ! bdb_ask "Do you want to install Visual Studio Code"; then
    bdb_warn "Skipping Visual Studio Code installation"
    bdb_end_section
    exit 0
fi

{{- if eq .chezmoi.os "darwin" }}
bdb_exec "Installing Visual Studio Code" brew install --cask visual-studio-code
bdb_success "Visual Studio Code installed"

{{- else if eq .chezmoi.os "linux" }}

  {{- if eq .packageManager "apt" }}
bdb_action "Installing Visual Studio Code (Debian/Ubuntu)"

if [[ ! -f /etc/apt/keyrings/packages.microsoft.gpg ]]; then
    bdb_exec "Adding Microsoft GPG key" bash -c "wget -qO- https://packages.microsoft.com/keys/microsoft.asc | \
        gpg --dearmor > packages.microsoft.gpg && \
        sudo install -D -o root -g root -m 644 packages.microsoft.gpg /etc/apt/keyrings/packages.microsoft.gpg && \
        rm -f packages.microsoft.gpg"

    bdb_exec "Adding VS Code repository" bash -c "echo \
            'deb [arch=amd64,arm64,armhf signed-by=/etc/apt/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main' | \
            sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null"
else
    bdb_success "VS Code repository already configured"
fi

bdb_exec "Installing VS Code" bash -c "sudo apt-get update && sudo apt-get install -y code"
bdb_success "Visual Studio Code installed"

  {{- else if eq .packageManager "dnf" }}
bdb_action "Installing Visual Studio Code (Fedora/RHEL)"

bdb_exec "Importing Microsoft GPG key" sudo rpm --import https://packages.microsoft.com/keys/microsoft.asc

if [[ ! -f /etc/yum.repos.d/vscode.repo ]]; then
    bdb_exec "Adding VS Code repository" sudo sh -c 'cat > /etc/yum.repos.d/vscode.repo <<EOF
[code]
name=Visual Studio Code
baseurl=https://packages.microsoft.com/yumrepos/vscode
enabled=1
gpgcheck=1
gpgkey=https://packages.microsoft.com/keys/microsoft.asc
EOF'
else
    bdb_success "VS Code repository already configured"
fi

bdb_exec "Installing VS Code" sudo dnf install -y code
bdb_success "Visual Studio Code installed"

  {{- else if eq .packageManager "pacman" }}
# visual-studio-code-bin is AUR-only, so yay is mandatory here.
# 00-install-core bootstraps it from the `yay` entry in .chezmoidata.toml;
# if that has not run yet, skip rather than fail the whole apply.
if ! bdb_has_cmd "yay"; then
    bdb_warn "Skipping VS Code — yay not found (00-install-core installs it)"
    bdb_end_section
    exit 0
fi

bdb_exec "Installing Visual Studio Code (Arch/Manjaro)" yay -S --needed --noconfirm visual-studio-code-bin
bdb_success "Visual Studio Code installed"

  {{- end }}
{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================

bdb_script_end "Visual Studio Code installation complete"

exit 0
