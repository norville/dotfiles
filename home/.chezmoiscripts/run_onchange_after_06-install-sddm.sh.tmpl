#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Install SDDM Configuration and Theme
# =============================================================================
# Deploys the Tokyo Night Moon SDDM theme and system-level SDDM configuration.
# Target paths require root:
#   /etc/sddm.conf
#   /etc/sddm.conf.d/tokyonight-moon.conf
#   /etc/sddm/Xsetup
#   /usr/share/sddm/themes/tokyonight-moon/
#
# Changes take effect on the next SDDM start (reboot or manual restart).
# This script does NOT restart SDDM automatically to avoid killing the session.
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_06-install-sddm.sh.tmpl
# =============================================================================
# Managed file checksums — changes here trigger a re-run:
# sddm.conf:              {{ include "sddm/etc/sddm.conf" | sha256sum }}
# tokyonight-moon.conf:   {{ include "sddm/etc/sddm.conf.d/tokyonight-moon.conf" | sha256sum }}
# metadata.desktop:       {{ include "sddm/themes/tokyonight-moon/metadata.desktop" | sha256sum }}
# Main.qml:               {{ include "sddm/themes/tokyonight-moon/Main.qml" | sha256sum }}
# LoginFormComponent.qml: {{ include "sddm/themes/tokyonight-moon/LoginFormComponent.qml" | sha256sum }}
# Xsetup:                 {{ include "sddm/etc/sddm/Xsetup" | sha256sum }}
# background.jpg:         {{ output "sha256sum" (joinPath .chezmoi.sourceDir "sddm/themes/tokyonight-moon/background.jpg") }}
{{- /* Workstation machines with SDDM installed only. */ -}}
{{- if or (ne .machine "workstation") (not (lookPath "sddm")) }}
exit 0
{{- end }}

source "${HELPERS}"

bdb_script_init "${BASH_SOURCE[0]}"

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
THEME_DIR="/usr/share/sddm/themes/tokyonight-moon"

# =============================================================================
# WRITE EXPECTED CONTENT TO TEMP DIRECTORY
# =============================================================================
# Content is embedded once here — used for both the idempotency check below
# and deployment. This avoids duplicating template includes.

_TMP=$(mktemp -d)
trap 'rm -rf "$_TMP"; bdb_cleanup' EXIT

cat > "$_TMP/sddm.conf" << 'SDDM_EOF'
{{ include "sddm/etc/sddm.conf" -}}
SDDM_EOF

cat > "$_TMP/tokyonight-moon.conf" << 'SDDM_EOF'
{{ include "sddm/etc/sddm.conf.d/tokyonight-moon.conf" -}}
SDDM_EOF

cat > "$_TMP/Xsetup" << 'SDDM_EOF'
{{ include "sddm/etc/sddm/Xsetup" -}}
SDDM_EOF

cat > "$_TMP/metadata.desktop" << 'SDDM_EOF'
{{ include "sddm/themes/tokyonight-moon/metadata.desktop" -}}
SDDM_EOF

cat > "$_TMP/Main.qml" << 'SDDM_EOF'
{{ include "sddm/themes/tokyonight-moon/Main.qml" -}}
SDDM_EOF

cat > "$_TMP/LoginFormComponent.qml" << 'SDDM_EOF'
{{ include "sddm/themes/tokyonight-moon/LoginFormComponent.qml" -}}
SDDM_EOF

cp "${SOURCE_DIR}/sddm/themes/tokyonight-moon/background.jpg" "$_TMP/background.jpg"

# =============================================================================
# IDEMPOTENCY CHECK
# =============================================================================
# All target files are world-readable (644/755), so no sudo needed here.
# cmp -s exits 0 only when files exist and are byte-identical.
# xrandr must be present too — /etc/sddm/Xsetup calls it to lay out the
# monitors, so a matching Xsetup with no xrandr binary is still broken.
# If everything already matches, exit silently without prompting.

if     cmp -s "$_TMP/sddm.conf"              /etc/sddm.conf                        2>/dev/null \
    && cmp -s "$_TMP/tokyonight-moon.conf"   /etc/sddm.conf.d/tokyonight-moon.conf 2>/dev/null \
    && cmp -s "$_TMP/Xsetup"                 /etc/sddm/Xsetup                      2>/dev/null \
    && cmp -s "$_TMP/metadata.desktop"       "${THEME_DIR}/metadata.desktop"       2>/dev/null \
    && cmp -s "$_TMP/Main.qml"               "${THEME_DIR}/Main.qml"               2>/dev/null \
    && cmp -s "$_TMP/LoginFormComponent.qml" "${THEME_DIR}/LoginFormComponent.qml" 2>/dev/null \
    && cmp -s "$_TMP/background.jpg"         "${THEME_DIR}/background.jpg"         2>/dev/null \
    && bdb_has_cmd xrandr; then
    bdb_success "SDDM configuration and theme are already up to date"
    exit 0
fi

bdb_ask "Install SDDM configuration and theme?" || { bdb_warn "Skipped by user"; exit 0; }

# =============================================================================
# SDDM SYSTEM CONFIGURATION
# =============================================================================

bdb_begin_section "Installing SDDM configuration"

{{- /* xrandr powers /etc/sddm/Xsetup — package name differs per manager. */}}
    if ! bdb_has_cmd xrandr; then
{{- if eq .packageManager "pacman" }}
        bdb_exec "Installing xrandr (xorg-xrandr)" sudo pacman -S --needed --noconfirm xorg-xrandr
{{- else if eq .packageManager "apt" }}
        bdb_exec "Installing xrandr (x11-xserver-utils)" sudo apt-get install -y x11-xserver-utils
{{- else if eq .packageManager "dnf" }}
        bdb_exec "Installing xrandr" sudo dnf install -y xrandr
{{- end }}
    else
        bdb_success "xrandr already installed"
    fi

    bdb_action "Writing /etc/sddm.conf"
    sudo install -m 644 "$_TMP/sddm.conf" /etc/sddm.conf
    bdb_success "Written /etc/sddm.conf"

    bdb_action "Writing /etc/sddm.conf.d/tokyonight-moon.conf"
    sudo mkdir -p /etc/sddm.conf.d
    sudo install -m 644 "$_TMP/tokyonight-moon.conf" /etc/sddm.conf.d/tokyonight-moon.conf
    bdb_success "Written /etc/sddm.conf.d/tokyonight-moon.conf"

    bdb_action "Writing /etc/sddm/Xsetup"
    sudo mkdir -p /etc/sddm
    sudo install -m 755 "$_TMP/Xsetup" /etc/sddm/Xsetup
    bdb_success "Written /etc/sddm/Xsetup"

bdb_end_section

# =============================================================================
# SDDM THEME
# =============================================================================

bdb_begin_section "Installing Tokyo Night Moon SDDM theme"

    bdb_action "Creating theme directory"
    sudo install -d -m 755 "${THEME_DIR}"
    bdb_success "Created ${THEME_DIR}"

    bdb_action "Writing theme files"
    sudo install -m 644 "$_TMP/metadata.desktop"       "${THEME_DIR}/metadata.desktop"
    sudo install -m 644 "$_TMP/Main.qml"               "${THEME_DIR}/Main.qml"
    sudo install -m 644 "$_TMP/LoginFormComponent.qml" "${THEME_DIR}/LoginFormComponent.qml"
    sudo install -m 644 "$_TMP/background.jpg"         "${THEME_DIR}/background.jpg"
    bdb_success "Theme files installed to ${THEME_DIR}"

bdb_end_section

bdb_warn "SDDM changes take effect on the next login (restart SDDM or reboot to apply now)"
