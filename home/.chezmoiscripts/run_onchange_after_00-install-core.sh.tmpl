#!/usr/bin/env bash
# =============================================================================
# Chezmoi Script: Install Core Packages
# =============================================================================
# Builds install arrays by filtering .chezmoidata.toml at template render time.
# One pass per install mechanism (apt-get, snap, pacman, AUR, dnf, brew).
# GNOME-conditional packages (darkman, xdg-desktop-portal-gtk) are appended
# explicitly — they depend on XDG_CURRENT_DESKTOP, not just machine type.
#
# Execution: chezmoi apply (only when this file's content changes)
# Location:  .chezmoiscripts/run_onchange_after_00-install-core.sh.tmpl
# =============================================================================

# -----------------------------------------------------------------------------
# Setup
# -----------------------------------------------------------------------------
source "${HELPERS}"

bdb_script_init "${BASH_SOURCE[0]}"

# =============================================================================
# PACKAGE INSTALLATION
# =============================================================================

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* Linux                                                                */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- if eq .chezmoi.os "linux" }}

bdb_begin_section "Installing Required Packages for {{ .osid }} ({{ .machine }})"

  {{- /* ---------------------------------------------------------------- */ -}}
  {{- /* Debian / Ubuntu — APT + Snap                                     */ -}}
  {{- /* ---------------------------------------------------------------- */ -}}
  {{- if eq .packageManager "apt" }}

# -----------------------------------------------------------------------------
# External APT repositories
# -----------------------------------------------------------------------------

# eza — not in official repos; add signing key and custom source
if [[ ! -f /etc/apt/keyrings/gierens.gpg ]]; then
    bdb_action "Setting up eza repository"
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | sudo tee /etc/apt/sources.list.d/eza.list
    sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/eza.list
    bdb_success "eza repository configured"
else
    bdb_success "eza repository already configured"
fi

# OpenTofu — not in official repos; requires two GPG keys from opentofu.org
if [[ ! -f /etc/apt/keyrings/opentofu.gpg ]]; then
    bdb_action "Setting up OpenTofu repository"
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://get.opentofu.org/opentofu.gpg \
        | sudo tee /etc/apt/keyrings/opentofu.gpg >/dev/null
    wget -qO- https://packages.opentofu.org/opentofu/tofu/gpgkey \
        | sudo gpg --no-tty --batch --dearmor \
            -o /etc/apt/keyrings/opentofu-repo.gpg >/dev/null
    sudo chmod a+r /etc/apt/keyrings/opentofu.gpg \
                   /etc/apt/keyrings/opentofu-repo.gpg
    printf 'deb [signed-by=/etc/apt/keyrings/opentofu.gpg,/etc/apt/keyrings/opentofu-repo.gpg] https://packages.opentofu.org/opentofu/tofu/any/ any main\ndeb-src [signed-by=/etc/apt/keyrings/opentofu.gpg,/etc/apt/keyrings/opentofu-repo.gpg] https://packages.opentofu.org/opentofu/tofu/any/ any main\n' \
        | sudo tee /etc/apt/sources.list.d/opentofu.list >/dev/null
    sudo chmod a+r /etc/apt/sources.list.d/opentofu.list
    bdb_success "OpenTofu repository configured"
else
    bdb_success "OpenTofu repository already configured"
fi

    {{- if eq .machine "workstation" }}

# Brave Browser — not in official repos (workstation only)
if [[ ! -f /etc/apt/keyrings/brave-browser-archive-keyring.gpg ]]; then
    bdb_action "Setting up Brave Browser repository"
    sudo mkdir -p /etc/apt/keyrings
    sudo wget -qO /etc/apt/keyrings/brave-browser-archive-keyring.gpg \
        https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
    echo "deb [signed-by=/etc/apt/keyrings/brave-browser-archive-keyring.gpg arch=amd64] \
https://brave-browser-apt-release.s3.brave.com/ stable main" \
        | sudo tee /etc/apt/sources.list.d/brave-browser-release.list
    sudo chmod 644 /etc/apt/keyrings/brave-browser-archive-keyring.gpg \
        /etc/apt/sources.list.d/brave-browser-release.list
    bdb_success "Brave Browser repository configured"
else
    bdb_success "Brave Browser repository already configured"
fi

# Zed — not in official repos; use debian.griffo.io (workstation only)
if [[ ! -f /etc/apt/trusted.gpg.d/debian.griffo.io.gpg ]]; then
    bdb_action "Setting up Zed repository"
    wget -qO- https://debian.griffo.io/EA0F721D231FDD3A0A17B9AC7808B4DD62C41256.asc \
        | sudo gpg --dearmor --yes -o /etc/apt/trusted.gpg.d/debian.griffo.io.gpg
    echo "deb https://debian.griffo.io/apt $(lsb_release -sc 2>/dev/null) main" \
        | sudo tee /etc/apt/sources.list.d/debian.griffo.io.list
    sudo chmod 644 /etc/apt/trusted.gpg.d/debian.griffo.io.gpg \
        /etc/apt/sources.list.d/debian.griffo.io.list
    bdb_success "Zed repository configured"
else
    bdb_success "Zed repository already configured"
fi

    {{- end }}

# -----------------------------------------------------------------------------
# APT packages
# -----------------------------------------------------------------------------
APT_PACKAGES=(
    {{- range .package }}
      {{- if and (has $.machine .machines) (has "apt" .managers) }}
    "{{ .name }}"
      {{- end }}
    {{- end }}
)

bdb_exec "Updating APT package lists" sudo apt-get update
bdb_exec "Installing APT packages"    sudo apt-get install -y "${APT_PACKAGES[@]}"

# -----------------------------------------------------------------------------
# Snap packages (chezmoi, lazygit, nvim, yazi — absent/outdated in apt)
# -----------------------------------------------------------------------------
SNAP_PACKAGES=(
    {{- range .package }}
      {{- if and (has $.machine .machines) (has "snap" .managers) }}
    "{{ .name }}"
      {{- end }}
    {{- end }}
)

if bdb_test_cmd "snap"; then
    bdb_exec "Refreshing installed snaps" sudo snap refresh
    # --classic cannot be combined with multiple packages in one call
    for _snap in "${SNAP_PACKAGES[@]}"; do
        if snap list "${_snap}" &>/dev/null; then
            bdb_success "Already installed: ${_snap}"
        else
            bdb_exec "Installing snap: ${_snap}" sudo snap install --classic "${_snap}"
        fi
    done
    unset _snap
else
    bdb_warn "snapd is not installed — skipping: ${SNAP_PACKAGES[*]}"
fi

  {{- /* ---------------------------------------------------------------- */ -}}
  {{- /* Fedora / Rocky — DNF                                             */ -}}
  {{- /* ---------------------------------------------------------------- */ -}}
  {{- else if eq .packageManager "dnf" }}

# -----------------------------------------------------------------------------
# External DNF repositories — COPR and upstream repos
# -----------------------------------------------------------------------------

bdb_action "Enabling COPR repositories"
sudo dnf copr enable -y alternateved/eza   2>/dev/null || true  # eza
sudo dnf copr enable -y atim/lazygit       2>/dev/null || true  # lazygit
sudo dnf copr enable -y atim/starship      2>/dev/null || true  # starship
sudo dnf copr enable -y awood/bat-extras   2>/dev/null || true  # bat-extras
sudo dnf copr enable -y pennbauman/ports   2>/dev/null || true  # zoxide
bdb_success "COPR repositories enabled"

    {{- if eq .machine "workstation" }}

# yazi — COPR (workstation only)
sudo dnf copr enable -y varlad/yazi 2>/dev/null || true
bdb_success "yazi COPR enabled"

# Brave Browser — not in official repos (workstation only)
if [[ ! -f /etc/yum.repos.d/brave-browser.repo ]]; then
    bdb_action "Setting up Brave Browser repository"
    sudo dnf install -y dnf-plugins-core
    sudo rpm --import https://brave-browser-rpm-release.s3.brave.com/brave-core.asc
    sudo tee /etc/yum.repos.d/brave-browser.repo > /dev/null <<'BRAVE_REPO_EOF'
[brave-browser]
name=Brave Browser
enabled=1
autorefresh=1
baseurl=https://brave-browser-rpm-release.s3.brave.com/x86_64/
gpgcheck=1
gpgkey=https://brave-browser-rpm-release.s3.brave.com/brave-core.asc
BRAVE_REPO_EOF
    bdb_success "Brave Browser repository configured"
else
    bdb_success "Brave Browser repository already configured"
fi

# Zed — via Terra repository (workstation only)
if [[ ! -f /etc/yum.repos.d/terra.repo ]]; then
    bdb_action "Setting up Terra repository (for Zed)"
    sudo dnf install -y \
        "https://github.com/terrapkg/subatomic-repos/raw/main/terra.repo" \
        2>/dev/null || \
    sudo dnf config-manager --add-repo \
        https://terra.fyralabs.com/terra.repo
    bdb_success "Terra repository configured"
else
    bdb_success "Terra repository already configured"
fi

    {{- end }}

# -----------------------------------------------------------------------------
# DNF packages
# -----------------------------------------------------------------------------
DNF_PACKAGES=(
    {{- range .package }}
      {{- if and (has $.machine .machines) (has "dnf" .managers) }}
    "{{ .name }}"
      {{- end }}
    {{- end }}
    {{- if and (eq .machine "workstation") (contains "gnome" (env "XDG_CURRENT_DESKTOP" | lower)) }}
    "darkman"
    "xdg-desktop-portal-gtk"
    {{- end }}
)

bdb_exec "Installing DNF packages" sudo dnf install -y "${DNF_PACKAGES[@]}"

  {{- /* ---------------------------------------------------------------- */ -}}
  {{- /* Arch / CachyOS — Pacman + AUR                                    */ -}}
  {{- /* ---------------------------------------------------------------- */ -}}
  {{- else if eq .packageManager "pacman" }}

# -----------------------------------------------------------------------------
# Pacman packages
# -----------------------------------------------------------------------------
PACMAN_PACKAGES=(
    {{- range .package }}
      {{- if and (has $.machine .machines) (has "pacman" .managers) }}
    "{{ .name }}"
      {{- end }}
    {{- end }}
    {{- if contains "gnome" (env "XDG_CURRENT_DESKTOP" | lower) }}
    "darkman"
    "xdg-desktop-portal-gtk"
    {{- end }}
)

bdb_exec "Installing Pacman packages" sudo pacman -S --needed --noconfirm "${PACMAN_PACKAGES[@]}"

# -----------------------------------------------------------------------------
# AUR packages
# -----------------------------------------------------------------------------
AUR_PACKAGES=(
    {{- range .package }}
      {{- if and (has $.machine .machines) (has "aur" .managers) }}
    "{{ .name }}"
      {{- end }}
    {{- end }}
)

if [[ ${#AUR_PACKAGES[@]} -gt 0 ]]; then
    if ! bdb_test_cmd "yay"; then
        bdb_action "Installing yay (AUR helper)"
        # Refresh sudo timestamp once so both makepkg pacman calls share the session
        sudo -v
        git clone https://aur.archlinux.org/yay.git /tmp/yay
        (cd /tmp/yay && makepkg -si --noconfirm)
        rm -rf /tmp/yay
        bdb_success "yay installed"
    else
        bdb_success "yay already installed"
    fi

    bdb_exec "Installing AUR packages" yay -S --needed --noconfirm "${AUR_PACKAGES[@]}"
fi

  {{- end }}

{{- /* -------------------------------------------------------------------- */ -}}
{{- /* macOS                                                                */ -}}
{{- /* -------------------------------------------------------------------- */ -}}
{{- else if eq .chezmoi.os "darwin" }}

bdb_begin_section "Installing Required Packages for macOS"

# All macOS packages are declared in the Brewfile (formulae + casks);
# brew bundle installs or upgrades them in a single idempotent pass.
BREWFILE="${HOME}/.config/homebrew/brewfile"

if [[ ! -f "${BREWFILE}" ]]; then
    bdb_error "Brewfile not found at ${BREWFILE}"
    exit 1
fi

bdb_var "Brewfile" "${BREWFILE}"
bdb_exec "Installing Homebrew packages" brew bundle --file="${BREWFILE}"

{{- end }}

# =============================================================================
# COMPLETION
# =============================================================================
bdb_script_end "Required packages installed successfully"

exit 0
